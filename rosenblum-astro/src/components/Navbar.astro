---
import languages from '../data/languages.json';

interface Props {
  currentLang?: 'de' | 'ru' | 'uk';
}
const { currentLang = 'de' } = Astro.props;
---

<header class="navbar">
  <div class="container navbar-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Rosenblum Übersetzungsbüro – Startseite">
      <div class="logo-circle">
        <svg width="22" height="22" viewBox="0 0 22 22" aria-hidden="true">
          <text
            x="50%"
            y="50%"
            text-anchor="middle"
            dy=".35em"
            fill="white"
            font-size="14"
            font-weight="700"
            font-family="Inter, sans-serif">R</text>
        </svg>
      </div>
      <div class="logo-text">
        <span class="logo-name">ROSENBLUM</span>
        <span class="logo-sub">ÜBERSETZUNGSBÜRO</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links" aria-label="Hauptnavigation">
      <div class="nav-item nav-dropdown">
        <button
          class="nav-link dropdown-trigger"
          aria-expanded="false"
          aria-haspopup="true"
          id="leistungen-btn">
          Unsere Leistungen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="dropdown-menu" id="leistungen-menu" role="menu">
          <div class="dropdown-col">
            <span class="dropdown-heading">Sprachen</span>
            {languages.map((l) => (
              <a href={`/beglaubigte-uebersetzung/${l.slug}`} class="dropdown-item" role="menuitem">
                <img src={l.flag} alt="" width="18" height="13" class="dropdown-flag" /> {l.name} → Deutsch
              </a>
            ))}
          </div>
          <div class="dropdown-col">
            <span class="dropdown-heading">Dokumente</span>
            <a href="/beglaubigte-uebersetzung/geburtsurkunde" class="dropdown-item" role="menuitem">📄 Geburtsurkunde</a>
            <a href="/beglaubigte-uebersetzung/heiratsurkunde" class="dropdown-item" role="menuitem">📄 Heiratsurkunde</a>
            <a href="/beglaubigte-uebersetzung/fuehrerschein" class="dropdown-item" role="menuitem">📄 Führerschein</a>
            <a href="/beglaubigte-uebersetzung/diplom" class="dropdown-item" role="menuitem">📄 Diplom / Zeugnis</a>
            <a href="/beglaubigte-uebersetzung/fuehrungszeugnis" class="dropdown-item" role="menuitem">📄 Führungszeugnis</a>
          </div>
        </div>
      </div>
      <a href="/ueber-uns" class="nav-link">Über uns</a>
      <a href="/preise" class="nav-link">Preise</a>
      <a href="#faq" class="nav-link">FAQ</a>
      <a href="/kontakt" class="nav-link">Kontakt</a>
    </nav>

    <!-- Right side -->
    <div class="nav-right">
      <div class="lang-switcher" role="navigation" aria-label="Sprachauswahl">
        <a
          href="/"
          class={`lang-btn${currentLang === 'de' ? ' active' : ''}`}
          aria-label="Deutsche Version"
          aria-current={currentLang === 'de' ? 'page' : undefined}>
          <img src="/media/flags/de.svg" alt="" width="18" height="13" class="lang-flag" />
          <span class="lang-code-label">DE</span>
        </a>
        <a
          href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/"
          class={`lang-btn${currentLang === 'ru' ? ' active' : ''}`}
          aria-label="Russische Version"
          aria-current={currentLang === 'ru' ? 'page' : undefined}>
          <img src="/media/flags/ru.svg" alt="" width="18" height="13" class="lang-flag" />
          <span class="lang-code-label">RU</span>
        </a>
        <a
          href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/"
          class={`lang-btn${currentLang === 'uk' ? ' active' : ''}`}
          aria-label="Ukrainische Version"
          aria-current={currentLang === 'uk' ? 'page' : undefined}>
          <img src="/media/flags/ua.svg" alt="" width="18" height="13" class="lang-flag" />
          <span class="lang-code-label">UA</span>
        </a>
      </div>
      <a href="/app/bestellen" class="btn-primary nav-cta">ÜBERSETZUNG BESTELLEN</a>
    </div>

    <!-- Hamburger -->
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu">
      <span class="hbar"></span>
      <span class="hbar"></span>
      <span class="hbar"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" hidden aria-label="Mobilnavigation">
    <div class="mobile-menu-inner">
      {languages.map((l) => (
        <a href={`/beglaubigte-uebersetzung/${l.slug}`} class="mobile-link">
          <img src={l.flag} alt="" width="18" height="13" class="dropdown-flag" /> {l.name} → Deutsch
        </a>
      ))}
      <div class="mobile-divider"></div>
      <a href="/ueber-uns" class="mobile-link">Über uns</a>
      <a href="/preise" class="mobile-link">Preise</a>
      <a href="#faq" class="mobile-link" id="mobile-faq-link">FAQ</a>
      <a href="/kontakt" class="mobile-link">Kontakt</a>
      <div class="mobile-divider"></div>
      <div class="mobile-lang">
        <a href="/" class={`lang-btn${currentLang === 'de' ? ' active' : ''}`} aria-label="Deutsch">
          <img src="/media/flags/de.svg" alt="" width="18" height="13" class="lang-flag" /><span class="lang-code-label">DE</span>
        </a>
        <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/" class={`lang-btn${currentLang === 'ru' ? ' active' : ''}`} aria-label="Russisch">
          <img src="/media/flags/ru.svg" alt="" width="18" height="13" class="lang-flag" /><span class="lang-code-label">RU</span>
        </a>
        <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/" class={`lang-btn${currentLang === 'uk' ? ' active' : ''}`} aria-label="Ukrainisch">
          <img src="/media/flags/ua.svg" alt="" width="18" height="13" class="lang-flag" /><span class="lang-code-label">UA</span>
        </a>
      </div>
      <a href="/app/bestellen" class="btn-primary" style="width:100%; margin-top:8px;">ÜBERSETZUNG BESTELLEN</a>
    </div>
  </div>
</header>

<script>
  // Hamburger toggle
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.hidden;
    if (mobileMenu) mobileMenu.hidden = isOpen;
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    hamburger.classList.toggle('open', !isOpen);
  });

  // Close mobile menu when FAQ link is clicked (anchor)
  document.getElementById('mobile-faq-link')?.addEventListener('click', () => {
    if (mobileMenu) mobileMenu.hidden = true;
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.classList.remove('open');
  });

  // Dropdown toggle
  const dropdownBtn = document.getElementById('leistungen-btn');
  const dropdownMenu = document.getElementById('leistungen-menu');

  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdownBtn.getAttribute('aria-expanded') === 'true';
    dropdownBtn.setAttribute('aria-expanded', String(!isOpen));
    dropdownMenu?.classList.toggle('visible', !isOpen);
  });

  document.addEventListener('click', () => {
    dropdownBtn?.setAttribute('aria-expanded', 'false');
    dropdownMenu?.classList.remove('visible');
  });

  // Escape key closes menus
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (mobileMenu) mobileMenu.hidden = true;
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.classList.remove('open');
      dropdownBtn?.setAttribute('aria-expanded', 'false');
      dropdownMenu?.classList.remove('visible');
    }
  });
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    height: 64px;
    gap: 0;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 32px;
  }

  .logo-circle {
    width: 38px;
    height: 38px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-name {
    font-size: 0.8125rem;
    font-weight: var(--font-bold);
    color: var(--color-text);
    letter-spacing: 0.06em;
  }

  .logo-sub {
    font-size: 0.5625rem;
    font-weight: var(--font-medium);
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
  }

  /* Desktop nav */
  .nav-links {
    display: none;
    align-items: center;
    gap: 2px;
    flex: 1;
  }

  @media (min-width: 1024px) {
    .nav-links { display: flex; }
  }

  .nav-item { position: relative; }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* Dropdown */
  .dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    padding: 16px;
    min-width: 380px;
    gap: 16px;
    z-index: 100;
    flex-direction: row;
  }

  .dropdown-menu.visible { display: flex; }

  .dropdown-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dropdown-heading {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 8px;
    margin-bottom: 4px;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
    white-space: nowrap;
  }

  .dropdown-item:hover {
    background: var(--color-bg-soft);
    color: var(--color-primary);
  }

  /* Right side */
  .nav-right {
    display: none;
    align-items: center;
    gap: 12px;
    margin-left: auto;
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .nav-right { display: flex; }
  }

  /* Lang switcher */
  .lang-switcher {
    display: flex;
    gap: 6px;
  }

  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }

  .lang-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .lang-btn.active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .lang-flag { display: block; border-radius: 2px; object-fit: cover; box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08); flex-shrink: 0; }

  .dropdown-flag { border-radius: 2px; object-fit: cover; box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08); vertical-align: middle; }

  .lang-code-label {
    font-size: 11px;
    font-weight: var(--font-bold);
    letter-spacing: 0.04em;
  }

  .nav-cta {
    padding: 10px 18px;
    font-size: 11px;
  }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
    flex-shrink: 0;
    border-radius: 6px;
  }

  @media (min-width: 1024px) {
    .hamburger { display: none; }
  }

  .hbar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.22s ease, opacity 0.22s ease;
    transform-origin: center;
  }

  .hamburger.open .hbar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open .hbar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open .hbar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 64px 0 0 0;
    background: white;
    border-top: 1px solid var(--color-border);
    z-index: 49;
    overflow-y: auto;
  }

  .mobile-menu[hidden] { display: none; }

  @media (min-width: 1024px) {
    .mobile-menu { display: none !important; }
  }

  .mobile-menu-inner {
    padding: 20px 24px 40px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 13px 12px;
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.12s;
  }

  .mobile-link:hover { background: var(--color-bg-soft); }

  .mobile-divider {
    height: 1px;
    background: var(--color-border);
    margin: 8px 0;
  }

  .mobile-lang {
    display: flex;
    gap: 8px;
    padding: 8px 0;
  }
</style>
