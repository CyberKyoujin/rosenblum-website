const situations = [
  {
    icon: 'filecheck',
    title: 'Ведомство по делам иностранцев',
    text: 'Для оформления статуса пребывания и продления вида на жительство.',
    items: ['Свидетельство о рождении', 'Паспорт (страница с данными)', 'Свидетельство о браке'],
  },
  {
    icon: 'star',
    title: 'Получение гражданства',
    text: 'Для подачи заявления на немецкое гражданство необходимы заверенные переводы украинских документов.',
    items: ['Свидетельство о рождении', 'Свидетельство о браке (если есть)', 'Возможно апостиль'],
  },
  {
    icon: 'graduation',
    title: 'Университет / Uni-Assist',
    text: 'Для поступления через Uni-Assist нужны заверенные переводы аттестата и диплома.',
    items: ['Аттестат с приложением оценок', 'Диплом (если есть)'],
  },
  {
    icon: 'briefcase',
    title: 'Jobcenter / Признание профессии',
    text: 'Jobcenter может оплатить перевод. Мы выставляем счёт напрямую — вы не платите ничего.',
    items: ['Трудовая книжка', 'Диплом / Аттестат', 'Jobcenter оплачивает'],
    badge: 'Jobcenter оплачивает',
  },
  {
    icon: 'heart',
    title: 'ЗАГС / Бракосочетание',
    text: 'Для регистрации брака в Германии нужны заверенные переводы украинских документов.',
    items: ['Свидетельство о рождении', 'Справка о несудимости', 'Решение о разводе (если есть)'],
  },
];

const reviews = [
  {
    initials: 'ЕК',
    name: 'Елена Коваленко',
    city: 'Берлин',
    text: 'В течение 30 минут получила расчёт для Jobcenter. Перевод пришёл вовремя, всё приняли без вопросов.',
  },
  {
    initials: 'ДА',
    name: 'Дмитрий Антонов',
    city: 'Мюнхен',
    text: 'Перевод диплома для Uni-Assist — идеально оформлено и заверено. Господин Розенблюм терпеливо ответил на все вопросы.',
  },
  {
    initials: 'ЮВ',
    name: 'Юлия Вебер',
    city: 'Кёльн',
    text: 'Экспресс за 24 часа. Именно то что мне было нужно для вида на жительство. Очень рекомендую.',
  },
];

const faqs = [
  {
    q: 'Нужен ли оригинал документа?',
    a: 'Нет. Для перевода достаточно фото или скана — даже снятого на телефон. Оригинал нужен только если ведомство требует чтобы перевод был физически прикреплён к оригиналу. Это редкий случай — мы сообщим в расчёте если это необходимо.',
  },
  {
    q: 'Сколько стоит заверенный перевод?',
    a: 'Стандартные документы (свидетельство о рождении, водительское удостоверение, паспорт) стоят от 30,30 € включая НДС — фиксированная цена, без сюрпризов. Сложные документы (диплом, трудовая книжка) оплачиваются по строкам: 1,40–1,80 € за строку. Бесплатный расчёт — за 30 минут.',
  },
  {
    q: 'Как долго ждать перевод?',
    a: 'Стандартный срок — 72 часа. С опцией Экспресс — 24 часа. Готовый перевод отправляем почтой по всей Германии. Цифровая копия PDF — сразу на email.',
  },
  {
    q: 'Примут ли перевод в ведомстве?',
    a: 'Да. Все переводы выполняет Олег Розенблюм — общеприсяжный переводчик при Земельном суде Ганновера. Переводы с официальной печатью и подписью признаны по всей Германии — во всех органах власти, судах и университетах.',
  },
  {
    q: 'Может ли Jobcenter оплатить перевод?',
    a: 'Да. Jobcenter и Agentur für Arbeit могут оплатить расходы на заверенный перевод. Вы подаёте наш расчёт куратору — после подтверждения мы выставляем счёт напрямую в Jobcenter. Вам не нужно платить.',
  },
  {
    q: 'Если мой документ на двух языках (украинский и русский)?',
    a: 'Это частый случай — многие украинские документы выпущенные до 2000-х годов содержат текст на обоих языках. Мы переводим весь документ целиком как один заказ — доплата за второй язык не взимается.',
  },
  {
    q: 'Нужен ли мне апостиль?',
    a: 'Это зависит от того, для чего вам нужен перевод. Для использования в Германии апостиль обычно не нужен — достаточно заверенного перевода. Но если документы нужны за рубежом, апостиль может потребоваться. Важно: мы оформляем апостиль именно на наш перевод, а не на ваш оригинальный документ. Апостиль на оригинал оформляется через Министерство юстиции Украины или соответствующий орган вашей страны. Апостиль на наш перевод: 35,00 € (Земельный суд Ганновера).',
  },
  {
    q: 'Как отправить документ?',
    a: 'Удобнее всего — через форму на сайте: загрузите фото, получите подтверждение сразу. Также можно отправить фото в WhatsApp или Telegram — ответим в течение 30 минут в рабочее время (Пн–Пт 9:00–18:00).',
  },
];

const translationSchema = {
  '@context': 'https://schema.org',
  '@type': 'TranslationService',
  name: 'Rosenblum Übersetzungsbüro',
  url: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/',
  serviceType: 'Заверенный перевод Украинский Немецкий',
  inLanguage: 'uk',
  outLanguage: 'de',
  provider: {
    '@type': 'Person',
    name: 'Oleg Rosenblum',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Vereidigter Übersetzer',
      recognizedBy: { '@type': 'Organization', name: 'Landgericht Hannover' },
    },
  },
  areaServed: { '@type': 'Country', name: 'Germany' },
  priceRange: 'от €30,30',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '50' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Русский', item: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/' },
  ],
};
---

<BaseLayout
  title="Переводчик украинского языка в Германии — заверенный перевод | Rosenblum"
  description="Заверенный перевод украинских документов на немецкий. Присяжный переводчик при Земельном суде Ганновера. Свидетельства, дипломы, водительские удостоверения от 30,30 €. Расчёт за 30 мин."
  lang="ru"
  canonicalUrl="https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/"
  hreflang={{
    ru: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/',
    de: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/',
    uk: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/',
  }}
  schema={[translationSchema, faqSchema, breadcrumbSchema]}
>
  <Navbar />

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="hero-section">
    <div class="container hero-grid">
      <!-- TEXT -->
      <div class="hero-text-top">
        <nav class="lang-switcher" aria-label="Язык страницы">
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/" class="lang-btn lang-btn--active" aria-current="page">
            <img src="/media/flags/ru.svg" width="20" height="14" alt="" aria-hidden="true" />
            Русский
          </a>
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/" class="lang-btn">
            <img src="/media/flags/de.svg" width="20" height="14" alt="" aria-hidden="true" />
            Deutsch
          </a>
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/" class="lang-btn">
            <img src="/media/flags/ua.svg" width="20" height="14" alt="" aria-hidden="true" />
            Українська
          </a>
        </nav>

        <div class="hero-status-badge" aria-label="Статус переводчика">
          <span class="hero-status-dot" aria-hidden="true"></span>
          Присяжный переводчик · Земельный суд Ганновера
        </div>

        <h1 class="hero-h1">
          Переводчик<br />
          <span class="hero-accent">украинского языка</span><br />
          в Германии
        </h1>
      </div>

      <!-- VISUAL -->
      <div class="hero-visual" aria-label="Пример заверенного перевода">
        <div class="hv-badge-top">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
          Заверено судом · Официально признано
        </div>

        <div class="hv-doc" aria-hidden="true">
          <div class="hv-doc-chip">ОРИГИНАЛ</div>
          <div class="hv-doc-title">СВИДЕТЕЛЬСТВО О РОЖДЕНИИ</div>
          <div class="hv-doc-country">Украина · Отдел ЗАГС</div>
          <div class="hv-doc-divider"></div>
          <div class="hv-doc-line" style="width:75%"></div>
          <div class="hv-doc-line" style="width:52%"></div>
          <div class="hv-doc-line" style="width:80%"></div>
          <div class="hv-doc-line" style="width:62%"></div>
          <div class="hv-doc-line" style="width:70%"></div>
          <div class="hv-doc-stamp">
            <div class="hv-stamp-text1">BEGLAUBIGT</div>
            <div class="hv-stamp-divline"></div>
            <div class="hv-stamp-text2">LG HANNOVER</div>
          </div>
        </div>

        <div class="hv-badge-bottom">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.clock} />
          Экспресс 24 ч · Доставка по всей Германии
        </div>
      </div>

      <div class="hero-text-bottom">
        <p class="hero-subline">
          Заверенный перевод украинских документов на немецкий — с печатью и подписью.
          Признано всеми ведомствами Германии.
          <strong class="hero-subline-accent">Доставка по всей Германии.</strong>
        </p>

        <ul class="hero-trust-list" aria-label="Преимущества">
          <li class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Присяжный при Земельном суде Ганновера</span>
          </li>
          <li class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>От 30,30 € · Стандарт 72 ч / Экспресс 24 ч</span>
          </li>
          <li class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>4,8/5 · 50 отзывов Google</span>
          </li>
        </ul>

        <div class="hero-cta">
          <a href="/app/bestellen" class="btn-primary">ЗАКАЗАТЬ ПЕРЕВОД →</a>
          <a href="/preise/" class="btn-secondary">Посмотреть цены →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: E-E-A-T ===== -->
  <section class="eeat-section">
    <div class="container eeat-grid">
      <div class="eeat-content">
        <p class="eeat-eyebrow">НАШИ ПОЛНОМОЧИЯ</p>
        <h2 class="eeat-h2">
          Олег Розенблюм —<br />
          <span class="eeat-accent">официально уполномоченный</span>
        </h2>
        <p class="eeat-text">
          Олег Розенблюм — общеприсяжный переводчик и уполномоченный переводчик при
          Земельном суде Ганновера для украинского и русского языков. Каждый перевод
          содержит официальную печать и подпись — признано по всей Германии.
        </p>
        <ul class="eeat-list" aria-label="Полномочия">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Уполномочен Земельным судом Ганновера</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span><span style="color:#93c5fd">Специалист по украинскому</span> и русскому с 2016 года</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Каждый перевод с официальной печатью и подписью</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Признано по всей Германии — всеми ведомствами</span>
          </li>
        </ul>
      </div>

      <!-- Register card -->
      <div class="eeat-register-card">
        <div class="register-icon-wrap">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.shieldcheck} />
        </div>
        <div class="register-label">JUSTIZ-DOLMETSCHER-REGISTER</div>
        <h3 class="register-name">Oleg Rosenblum</h3>
