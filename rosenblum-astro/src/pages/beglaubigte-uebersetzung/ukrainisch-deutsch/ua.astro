<script>
  // Tab switcher for "How it works" section
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('[data-target]');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => {
        b.classList.remove('tab-btn--active');
        b.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.tab-panel').forEach(p => {
        (p as HTMLElement).hidden = true;
      });
      btn.classList.add('tab-btn--active');
      btn.setAttribute('aria-selected', 'true');
      const target = document.getElementById(btn.dataset.target!);
      if (target) target.hidden = false;
    });
  });

  // FAQ: only one open at a time (native <details> with name="" handles this in modern browsers)
</script>

