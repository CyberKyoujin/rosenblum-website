const docs = [
  { icon: 'filetext', name: 'Свідоцтво про народження', de: 'Geburtsurkunde', usage: 'Для Einbürgerung, Standesamt, Kindergeld', price: '35,30 €', href: '/app/bestellen?doc=geburtsurkunde' },
  { icon: 'filetext', name: 'Свідоцтво про шлюб', de: 'Heiratsurkunde', usage: 'Для Standesamt, возз\'єднання сім\'ї', price: '35,30 €', href: '/app/bestellen?doc=heiratsurkunde' },
  { icon: 'idcard', name: 'Посвідчення водія', de: 'Führerschein', usage: 'Для обміну на німецькі права', price: '30,30 €', href: '/app/bestellen?doc=fuehrerschein', badge: 'Найдешевше' },
  { icon: 'idcard', name: 'Закордонний паспорт', de: 'Reisepass', usage: 'Для Ausländerbehörde', price: '35,30 €', href: '/app/bestellen?doc=pass' },
  { icon: 'shield', name: 'Довідка про несудимість', de: 'Führungszeugnis', usage: 'Для роботодавців, органів влади', price: '35,30 €', href: '/app/bestellen?doc=fuehrungszeugnis' },
  { icon: 'home', name: 'Довідка про реєстрацію', de: 'Meldebescheinigung', usage: 'Для органів влади, банків', price: '35,30 €', href: '/app/bestellen?doc=meldebescheinigung' },
];

const situations = [
  {
    icon: 'filecheck',
    title: 'Відомство у справах іноземців (§24)',
    text: 'Українці з тимчасовим захистом за §24 потребують засвідченого перекладу документів для оформлення посвідки на проживання.',
    items: ['Свідоцтво про народження', 'Паспорт (сторінка з даними)', 'Свідоцтво про шлюб (якщо є)'],
  },
  {
    icon: 'star',
    title: 'Отримання громадянства',
    text: 'Для заяви на отримання громадянства потрібні засвідчені переклади українських документів про особистий стан.',
    items: ['Свідоцтво про народження', 'Свідоцтво про шлюб (якщо є)', 'Апостиль (якщо є)'],
  },
  {
    icon: 'graduation',
    title: 'Університет / Uni-Assist',
    text: 'Для вступу до університету через Uni-Assist потрібні засвідчені переклади атестата та диплома.',
    items: ['Атестат з додатком оцінок', 'Диплом (якщо є)', 'Апостиль (якщо є)'],
  },
  {
    icon: 'briefcase',
    title: 'Jobcenter / Визнання професії',
    text: 'Jobcenter може оплатити переклад. Ми виставляємо рахунок напряму — ви не платите нічого.',
    items: ['Трудова книжка', 'Диплом / Атестат', 'Jobcenter оплачує'],
    badge: 'Jobcenter оплачує',
  },
  {
    icon: 'heart',
    title: 'РАЦС / Одруження',
    text: 'Для реєстрації шлюбу в Німеччині потрібні засвідчені переклади українських документів.',
    items: ['Свідоцтво про народження', 'Довідка про несудимість', 'Рішення про розлучення (якщо є)'],
  },
];

const reviews = [
  {
    initials: 'ОК',
    name: 'Олена Коваленко',
    city: 'Берлін',
    text: 'Протягом 30 хвилин отримала кошторис для Jobcenter. Переклад прийшов вчасно, все прийняли без питань.',
  },
  {
    initials: 'ДА',
    name: 'Дмитро Антонов',
    city: 'Мюнхен',
    text: 'Переклад диплома для Uni-Assist — ідеально оформлено та засвідчено. Пан Розенблюм терпляче відповів на всі питання.',
  },
  {
    initials: 'ЮВ',
    name: 'Юлія Вебер',
    city: 'Кельн',
    text: 'Експрес за 24 години. Саме те що мені було потрібно для посвідки на проживання. Дуже рекомендую.',
  },
];

const faqs = [
  {
    q: 'Чи потрібен оригінал документа?',
    a: 'Ні. Для перекладу достатньо фото або сканів — навіть знятого на телефон. Оригінал потрібен тільки якщо орган влади вимагає щоб переклад був фізично прикріплений до оригіналу. Це рідкісний випадок — ми повідомимо вас у кошторисі якщо це необхідно.',
  },
  {
    q: 'Скільки коштує засвідчений переклад?',
    a: 'Стандартні документи (свідоцтво про народження, посвідчення водія, паспорт) коштують від 30,30 € включно з ПДВ — фіксована ціна, без сюрпризів. Складні документи (диплом, трудова книжка) оплачуються по рядках: 1,40–1,80 € за рядок. Безкоштовний кошторис — за 30 хвилин.',
  },
  {
    q: 'Як довго чекати на переклад?',
    a: 'Стандартний термін — 72 години після підтвердження замовлення. З опцією Експрес — 24 години. Готовий переклад надсилаємо поштою по всій Німеччині. Цифрова копія PDF — одразу на email.',
  },
  {
    q: 'Чи приймуть переклад у відомстві?',
    a: 'Так. Всі переклади виконує Олег Розенблюм — загальноприсяжний перекладач при Земельному суді Ганновера. Переклади з офіційною печаткою та підписом визнані по всій Німеччині — у всіх органах влади, судах та університетах.',
  },
  {
    q: 'Чи може Jobcenter оплатити переклад?',
    a: 'Так. Jobcenter та Agentur für Arbeit можуть оплатити витрати на засвідчений переклад. Ви подаєте наш кошторис куратору — після підтвердження ми виставляємо рахунок напряму до Jobcenter. Вам не потрібно платити.',
  },
  {
    q: 'Чи перекладаєте ви з німецької на українську?',
    a: 'Так. Ми перекладаємо в обох напрямках — українські документи на німецьку і німецькі листи, рішення, договори на українську. На запит — також із засвідченням.',
  },
  {
    q: 'Чи потрібен мені апостиль?',
    a: 'Це залежить від того, для чого вам потрібен переклад. Для використання в Німеччині апостиль зазвичай не потрібен — достатньо засвідченого перекладу. Але якщо документи потрібні за кордоном, апостиль може знадобитися. Важливо: ми оформлюємо апостиль саме на наш переклад, а не на ваш оригінальний документ. Апостиль на оригінал оформлюється через Міністерство юстиції України або відповідний орган вашої країни. Апостиль на наш переклад: 35,00 € (Земельний суд Ганновера).',
  },
  {
    q: 'Як надіслати документ?',
    a: 'Найзручніше — через форму на сайті: завантажте фото, отримайте підтвердження одразу. Також можна надіслати фото у WhatsApp або Telegram — відповімо протягом 30 хвилин у робочий час (Пн–Пт 9:00–18:00).',
  },
];

const translationSchema = {
  '@context': 'https://schema.org',
  '@type': 'TranslationService',
  name: 'Rosenblum Übersetzungsbüro',
  url: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/',
  serviceType: 'Засвідчений переклад Українська Німецька',
  inLanguage: 'uk',
  outLanguage: 'de',
  provider: {
    '@type': 'Person',
    name: 'Oleg Rosenblum',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Vereidigter Übersetzer',
      recognizedBy: { '@type': 'Organization', name: 'Landgericht Hannover' },
    },
  },
  areaServed: { '@type': 'Country', name: 'Germany' },
  priceRange: 'від €30,30',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '50' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Українська', item: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/' },
  ],
};
---

<BaseLayout
  title="Присяжний перекладач у Німеччині — засвідчений переклад | Rosenblum"
  description="Засвідчений переклад українських документів — присяжний перекладач при Земельному суді Ганновера. Свідоцтво про народження, права, диплом від 30,30 €. Кошторис за 30 хв. По всій Німеччині."
  lang="uk"
  canonicalUrl="https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/"
  hreflang={{
    uk: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/',
    de: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/',
    ru: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/',
  }}
  schema={[translationSchema, faqSchema, breadcrumbSchema]}
>
  <Navbar />

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="hero-section">

    <div class="container hero-grid">
      <!-- TEXT -->
      <div class="hero-text-top">
        <!-- Lang switcher -->
        <nav class="lang-switcher" aria-label="Мова сторінки">
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/" class="lang-btn lang-btn--active" aria-current="page">
            <img src="/media/flags/ua.svg" width="20" height="14" alt="" aria-hidden="true" />
            Українська
          </a>
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/" class="lang-btn">
            <img src="/media/flags/de.svg" width="20" height="14" alt="" aria-hidden="true" />
            Deutsch
          </a>
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/" class="lang-btn">
            <img src="/media/flags/ru.svg" width="20" height="14" alt="" aria-hidden="true" />
            Русский
          </a>
        </nav>

        <h1 class="hero-h1">
          Засвідчений переклад<br />
          <span class="hero-accent">Українська–Німецька</span>
        </h1>
      </div>

      <!-- VISUAL -->
      <div class="hero-visual" aria-label="Приклад засвідченого перекладу">
        <div class="hv-badge-top">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
          Засвідчено судом · Офіційно визнано
        </div>

        <div class="hv-doc" aria-hidden="true">
          <div class="hv-doc-chip">ОРИГІНАЛ</div>
          <div class="hv-doc-title">СВІДОЦТВО ПРО НАРОДЖЕННЯ</div>
          <div class="hv-doc-country">Україна · Відділ РАЦС</div>
          <div class="hv-doc-divider"></div>
          <div class="hv-doc-line" style="width:78%"></div>
          <div class="hv-doc-line" style="width:55%"></div>
          <div class="hv-doc-line" style="width:82%"></div>
          <div class="hv-doc-line" style="width:60%"></div>
          <div class="hv-doc-line" style="width:70%"></div>
          <div class="hv-doc-stamp">
            <div class="hv-stamp-text1">BEGLAUBIGT</div>
            <div class="hv-stamp-divline"></div>
            <div class="hv-stamp-text2">LG HANNOVER</div>
          </div>
        </div>

        <div class="hv-badge-bottom">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.clock} />
          Експрес 24 год. · Доставка по всій Німеччині
        </div>
      </div>

      <div class="hero-text-bottom">
        <p class="hero-subline">
          Офіційний перекладач при Земельному суді Ганновера.
          Визнано у всіх органах влади, судах та університетах Німеччини.
          <strong class="hero-subline-accent">По всій Німеччині поштою.</strong>
        </p>

        <ul class="hero-trust-list" aria-label="Переваги">
          <li class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Присяжний при Земельному суді Ганновера</span>
          </li>
          <li class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Від 30,30 € · Стандарт 72 год / Експрес 24 год</span>
          </li>
          <li class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>4,8/5 · 50 відгуків на Google</span>
          </li>
        </ul>

        <div class="hero-cta">
          <a href="/app/bestellen" class="btn-primary">ЗАМОВИТИ ПЕРЕКЛАД →</a>
          <a href="/preise/" class="btn-secondary">Переглянути ціни →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: E-E-A-T ===== -->
  <section class="eeat-section">
    <div class="container eeat-grid">
      <div class="eeat-content">
        <p class="eeat-eyebrow">Чому варто довіряти</p>
        <h2 class="eeat-h2">
          Не просто перекладач —<br />
          <span class="eeat-accent">офіційно визнаний спеціаліст</span>
        </h2>
        <p class="eeat-text">
          Олег Розенблюм — загальноприсяжний перекладач та уповноважений перекладач при
          Земельному суді Ганновера (Niedersachsen). Лише присяжні перекладачі мають право
          виконувати юридично визнані засвідчені переклади в Німеччині.
        </p>
        <ul class="eeat-list" aria-label="Переваги">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Верифікований у реєстрі Нижньої Саксонії</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Офіційна печатка та власноручний підпис</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Визнано по всій Німеччині — від Flensburg до München</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
            <span>Мови: Українська · Російська · Німецька</span>
          </li>
        </ul>
      </div>

      <!-- Register card with photo -->
      <div class="register-card">
        <div class="register-photo-wrap">
          <img src="/media/oleg.jpg" class="register-photo" alt="Олег Розенблюм — присяжний перекладач при Земельному суді Ганновера" />
          <div class="register-photo-chip">
