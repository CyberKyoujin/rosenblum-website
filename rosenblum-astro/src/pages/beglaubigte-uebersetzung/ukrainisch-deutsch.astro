const faqs = [
  {
    q: 'Was kostet eine beglaubigte Übersetzung Ukrainisch–Deutsch?',
    a: 'Standarddokumente wie Geburtsurkunde, Heiratsurkunde oder Führerschein kosten ab 30,30 € inkl. MwSt. — Festpreis unabhängig von der genauen Seitenzahl. Den genauen Preis erhalten Sie in unserem kostenlosen Kostenvoranschlag innerhalb von 30 Minuten.',
  },
  {
    q: 'Wie lange dauert eine Übersetzung Ukrainisch–Deutsch?',
    a: 'Standarddokumente übersetzen wir in 72 Stunden. Mit Express-Option in 24 Stunden. Die fertige beglaubigte Übersetzung erhalten Sie per Post — deutschlandweit, ohne Aufpreis.',
  },
  {
    q: 'Wird die Übersetzung bei der Ausländerbehörde anerkannt?',
    a: 'Ja. Alle unsere Übersetzungen werden von Oleg Rosenblum erstellt — vereidigter Übersetzer am Landgericht Hannover. Sie sind mit offiziellem Siegel und handschriftlicher Unterschrift versehen und werden deutschlandweit von allen Behörden, Gerichten und Hochschulen anerkannt.',
  },
  {
    q: 'Kann das Jobcenter die Kosten übernehmen?',
    a: 'Ja. Das Jobcenter und die Agentur für Arbeit können die Kosten für beglaubigte Übersetzungen übernehmen. Sie reichen unseren Kostenvoranschlag bei Ihrem Sachbearbeiter ein — nach Bewilligung zahlt das Jobcenter direkt an uns.',
  },
  {
    q: 'Muss ich das Originaldokument einsenden?',
    a: 'Nein. Ein Foto oder Scan reicht aus. Das Original benötigen wir nur wenn die Behörde ausdrücklich verlangt, dass die Übersetzung am Original befestigt wird — das teilen wir Ihnen im Kostenvoranschlag mit.',
  },
  {
    q: 'Übersetzen Sie auch Deutsch–Ukrainisch?',
    a: 'Ja. Wir übersetzen in beide Richtungen — ukrainische Dokumente ins Deutsche und deutsche Bescheide, Briefe oder Dokumente ins Ukrainische. Auf Anfrage auch mit Beglaubigung.',
  },
  {
    q: 'Brauche ich auch eine Apostille?',
    a: 'Das hängt davon ab, wofür Sie die Übersetzung benötigen. Innerhalb Deutschlands ist in der Regel keine Apostille erforderlich — eine beglaubigte Übersetzung reicht aus. Wenn Ihre Dokumente jedoch im Ausland verwendet werden sollen, kann eine Apostille nötig sein. Wichtig: Wir stellen die Apostille auf unsere Übersetzung aus — nicht auf Ihr Originaldokument. Die Apostille auf das Original muss bei der zuständigen Behörde Ihres Herkunftslandes beantragt werden. Apostille auf unsere Übersetzung: 35,00 € (Landgericht Hannover).',
  },
  {
    q: 'Arbeiten Sie auch für Kunden außerhalb von Osnabrück?',
    a: 'Ja — wir arbeiten vollständig online und deutschlandweit. Dokumente hochladen, Übersetzung per Post erhalten — egal ob Berlin, Hamburg, München oder ein anderer Ort in Deutschland.',
  },
];

const translationSchema = {
  '@context': 'https://schema.org',
  '@type': 'TranslationService',
  name: 'Rosenblum Übersetzungsbüro',
  url: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/',
  serviceType: 'Beglaubigte Übersetzung Ukrainisch Deutsch',
  inLanguage: 'uk',
  outLanguage: 'de',
  provider: {
    '@type': 'Person',
    name: 'Oleg Rosenblum',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Vereidigter Übersetzer',
      recognizedBy: { '@type': 'Organization', name: 'Landgericht Hannover' },
    },
  },
  areaServed: { '@type': 'Country', name: 'Germany' },
  priceRange: 'ab €30,30',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '50' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Beglaubigte Übersetzungen', item: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzungen/' },
    { '@type': 'ListItem', position: 3, name: 'Ukrainisch–Deutsch', item: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/' },
  ],
};
---

<BaseLayout
  title="Übersetzer Ukrainisch Deutsch — beglaubigt & vereidigt | Rosenblum"
  description="Beglaubigte Übersetzungen Ukrainisch–Deutsch vom vereidigten Übersetzer am Landgericht Hannover. Geburtsurkunde, Führerschein, Diplom ab 30,30 €. Kostenvoranschlag in 30 Min. Deutschlandweit."
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/"
  hreflang={{
    de: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/',
    uk: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/',
    ru: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/',
  }}
  schema={[translationSchema, faqSchema, breadcrumbSchema]}
>
  <Navbar />

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="hero-section">
    <div class="hero-watermark" aria-hidden="true">
      <div class="hero-watermark-inner">
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
        <div class="hero-watermark-row">Переклад · Засвідчено · Документи · Офіційно · Переклад · Засвідчено · Документи · Офіційно ·</div>
      </div>
    </div>

    <div class="container hero-grid">
      <!-- TEXT: badge, h1, subline -->
      <div class="hero-text">
        <div class="hero-lang-pair">
          <div class="lang-pair-flag">
            <img src="/media/flags/ua.svg" width="24" height="16" alt="Ukrainisch" />
            <span>Ukrainisch</span>
          </div>
          <svg class="lang-pair-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.arrowright} />
          <div class="lang-pair-flag">
            <img src="/media/flags/de.svg" width="24" height="16" alt="Deutsch" />
            <span>Deutsch</span>
          </div>
        </div>

        <h1 class="hero-h1">
          Übersetzer<br />
          <span class="hero-accent">Ukrainisch Deutsch</span>
        </h1>
      </div>

      <!-- VISUAL: document stack (between text and bottom on mobile) -->
      <div class="hero-visual" aria-label="Dokument-Übersetzungsvorschau">

        <div class="hv-badge-top">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
          Vom Gericht beglaubigt · Amtlich anerkannt
        </div>

        <div class="hv-stack">
          <!-- Original UA doc (behind, rotated) -->
          <div class="hv-orig" aria-hidden="true">
            <div class="hv-orig-chip">ORIGINAL</div>
            <div class="hv-orig-heading">СВІДОЦТВО ПРО НАРОДЖЕННЯ</div>
            <div class="hv-orig-country">Україна · Відділ РАЦС</div>
            <div class="hv-orig-divider"></div>
            <div class="hv-orig-line" style="width:78%"></div>
            <div class="hv-orig-line" style="width:55%"></div>
            <div class="hv-orig-line" style="width:85%"></div>
            <div class="hv-orig-line" style="width:65%"></div>
            <div class="hv-orig-circle">П.П.</div>
          </div>

          <!-- Main certified translation -->
          <div class="hv-cert">
            <div class="hv-cert-topbar">
              <div>
                <div class="hv-cert-topbar-title">BEGLAUBIGTE ÜBERSETZUNG</div>
                <div class="hv-cert-topbar-sub">aus dem Ukrainischen ins Deutsche</div>
              </div>
              <div class="hv-cert-topbar-nr">Nr.&nbsp;UA-2026</div>
            </div>

            <div class="hv-cert-body">
              <div class="hv-cert-doctype">Geburtsurkunde</div>

              <div class="hv-cert-sep"></div>

              <div class="hv-cert-rows">
                <div class="hv-cert-row">
                  <span class="hv-cert-key">Name:</span>
                  <span class="hv-cert-dash">— — — — — — — —</span>
                </div>
                <div class="hv-cert-row">
                  <span class="hv-cert-key">Geburtsdatum:</span>
                  <span class="hv-cert-dash">— — — — — —</span>
                </div>
                <div class="hv-cert-row">
                  <span class="hv-cert-key">Geburtsort:</span>
                  <span class="hv-cert-dash">— — — — — — —</span>
                </div>
              </div>

              <div class="hv-cert-sep"></div>

              <p class="hv-cert-attest">
                Die Richtigkeit und Vollständigkeit vorstehender Übersetzung aus der ukrainischen Sprache wird beglaubigt.
              </p>

              <div class="hv-cert-footer">
                <div class="hv-stamp">
                  <div class="hv-stamp-text1">BEGLAUBIGT</div>
                  <div class="hv-stamp-divline"></div>
                  <div class="hv-stamp-text2">LG HANNOVER</div>
                </div>
                <div class="hv-sig">
                  <div class="hv-sig-name">O. Rosenblum</div>
                  <div class="hv-sig-role">Vereidigter Übersetzer</div>
                  <div class="hv-sig-court">Landgericht Hannover</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="hv-badge-bottom">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Express 24 Std. · Deutschlandweit per Post
        </div>

      </div>

      <!-- BOTTOM: subline, lang-switcher, CTA, trust -->
      <div class="hero-bottom">
        <p class="hero-subline">
          Beglaubigte Übersetzungen ukrainischer Dokumente —
          anerkannt bei allen deutschen Behörden, Gerichten
          und Hochschulen. Vereidigt am Landgericht Hannover.
          <strong class="hero-subline-accent">Deutschlandweit per Post.</strong>
        </p>

        <nav class="lang-switcher" aria-label="Sprachversion wählen">
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/" class="lang-btn lang-btn--active" aria-current="page">
            <img src="/media/flags/de.svg" width="18" height="12" alt="" aria-hidden="true" />
            Deutsch
          </a>
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/" class="lang-btn">
            <img src="/media/flags/ua.svg" width="18" height="12" alt="" aria-hidden="true" />
            Українська
          </a>
          <a href="/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/" class="lang-btn">
            <img src="/media/flags/ru.svg" width="18" height="12" alt="" aria-hidden="true" />
            Русский
          </a>
        </nav>

        <div class="hero-cta">
          <a href="/app/bestellen" class="btn-primary">ÜBERSETZUNG BESTELLEN →</a>
          <a href="/preise/" class="btn-secondary">Zur Preisliste →</a>
        </div>

        <div class="hero-trust-divider"></div>
        <ul class="hero-trust-list" aria-label="Vertrauenssignale">
          <li class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />Vereidigt LG Hannover</li>
          <li class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />Ab 30,30 € Festpreis</li>
          <li class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />Express 24 Std.</li>
          <li class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />Deutschlandweit</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: BIDIRECTIONAL ===== -->
  <section class="bidir-section">
    <div class="container">
      <div class="section-label">
        <span class="section-line"></span>
        <span>BEIDE RICHTUNGEN</span>
