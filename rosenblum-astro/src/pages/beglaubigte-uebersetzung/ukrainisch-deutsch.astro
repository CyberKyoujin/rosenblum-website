  border: 1px solid var(--color-border);
  border-radius: 20px;
  padding: 7px 16px;
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  color: var(--color-text);
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 6px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  z-index: 10;
}

@media (max-width: 639px) {
  .hv-badge-top {
    position: static;
    transform: none;
    margin-bottom: 14px;
    width: fit-content;
  }
}

.hv-badge-bottom {
  position: absolute;
  bottom: 0;
  right: 0;
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 20px;
  padding: 7px 14px;
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  color: var(--color-text);
  display: flex;
  align-items: center;
  gap: 6px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  z-index: 10;
}

@media (max-width: 639px) {
  .hv-badge-bottom {
    position: static;
    margin-top: 12px;
  }
}

/* Document stack */
.hv-stack {
  position: relative;
  min-height: 420px;
}

@media (max-width: 639px) {
  .hv-stack {
    position: static;
    min-height: auto;
  }
}

/* Original doc (behind, rotated) */
.hv-orig {
  position: absolute;
  top: 48px;
  left: 0;
  width: 50%;
  max-width: 195px;
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 14px;
  transform: rotate(-5deg);
  z-index: 1;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

@media (max-width: 639px) {
  .hv-orig { display: none; }
}

.hv-orig-chip {
  display: inline-block;
  font-size: 9px;
  font-weight: var(--font-bold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  background: var(--color-bg-soft);
  border-radius: 3px;
  padding: 2px 6px;
  margin-bottom: 8px;
}

.hv-orig-heading {
  font-size: 9px;
  font-weight: var(--font-bold);
  color: var(--color-text);
  text-align: center;
  margin-bottom: 3px;
  letter-spacing: 0.03em;
}

.hv-orig-country {
  font-size: 8px;
  color: var(--color-text-muted);
  text-align: center;
  margin-bottom: 8px;
}

.hv-orig-divider {
  height: 1px;
  background: var(--color-border);
  margin-bottom: 8px;
}

.hv-orig-line {
  height: 6px;
  background: var(--color-border);
  border-radius: 3px;
  margin-bottom: 6px;
  opacity: 0.55;
}

.hv-orig-circle {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 2px dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 8px;
  color: var(--color-text-muted);
  margin: 10px auto 0;
}

/* Main certified card */
.hv-cert {
  position: absolute;
  top: 0;
  right: 0;
  width: 80%;
  background: white;
  border: 2px solid var(--color-primary);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(59, 91, 219, 0.2);
  z-index: 2;
}

@media (max-width: 639px) {
  .hv-cert {
    position: static;
    width: 100%;
  }
}

.hv-cert-topbar {
  background: var(--color-primary);
  padding: 12px 18px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}

.hv-cert-topbar-title {
  color: white;
  font-size: 10px;
  font-weight: var(--font-bold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1.3;
}

.hv-cert-topbar-sub {
  color: rgba(255, 255, 255, 0.7);
  font-size: 9px;
  margin-top: 3px;
}

.hv-cert-topbar-nr {
  color: rgba(255, 255, 255, 0.55);
  font-size: 9px;
  flex-shrink: 0;
  align-self: flex-end;
}

.hv-cert-body { padding: 18px; }

.hv-cert-doctype {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--color-text);
}

.hv-cert-sep {
  height: 1px;
  background: var(--color-border);
  margin: 12px 0;
}

.hv-cert-rows {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.hv-cert-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: var(--text-xs);
}

.hv-cert-key {
  color: var(--color-text-muted);
  flex-shrink: 0;
  width: 96px;
  font-weight: var(--font-medium);
}

.hv-cert-dash {
  color: var(--color-border);
  letter-spacing: 0.06em;
  flex: 1;
  font-size: 11px;
}

.hv-cert-attest {
  font-size: 9px;
  color: var(--color-text-muted);
  line-height: 1.55;
  margin: 0 0 14px;
  font-style: italic;
}

.hv-cert-footer {
  display: flex;
  align-items: center;
  gap: 16px;
}

/* Circular stamp */
.hv-stamp {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: var(--color-primary);
  border: 4px solid white;
  box-shadow: 0 0 0 2px var(--color-primary), 0 8px 24px rgba(59, 91, 219, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  flex-shrink: 0;
}

.hv-stamp-text1 {
  color: white;
  font-size: 8.5px;
  font-weight: var(--font-black);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  line-height: 1;
}

.hv-stamp-divline {
  width: 40px;
  height: 1px;
  background: rgba(255, 255, 255, 0.4);
}

.hv-stamp-text2 {
  color: rgba(255, 255, 255, 0.85);
  font-size: 7.5px;
  font-weight: var(--font-bold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1;
}

/* Signature block */
.hv-sig { flex: 1; }

.hv-sig-name {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--color-text);
  font-style: italic;
  margin-bottom: 4px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--color-border);
}

.hv-sig-role {
  font-size: 10px;
  color: var(--color-text-muted);
  margin-top: 4px;
  margin-bottom: 2px;
}

.hv-sig-court {
  font-size: 10px;
  color: var(--color-primary);
  font-weight: var(--font-medium);
}

/* ===== SECTION 2: BIDIRECTIONAL ===== */
.bidir-section {
  background: var(--color-bg-soft);
  padding: var(--section-py) 0;
}

.bidir-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  margin-bottom: 20px;
}

@media (min-width: 768px) {
  .bidir-grid { grid-template-columns: 1fr 1fr; }
}

.bidir-card {
  background: white;
  border-radius: 12px;
  padding: 24px;
}

.bidir-card--main { border: 2px solid var(--color-primary); }
.bidir-card--secondary { border: 1px solid var(--color-border); background: var(--color-bg-soft); }

.bidir-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.bidir-flags {
  display: flex;
  align-items: center;
  gap: 6px;
}

.bidir-badge {
  font-size: 10px;
  font-weight: var(--font-semibold);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
}

.bidir-badge--primary { background: var(--color-primary); color: white; }
.bidir-badge--muted { background: var(--color-bg-soft); color: var(--color-text-muted); border: 1px solid var(--color-border); }

.bidir-h3 {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--color-text);
  margin: 0 0 10px;
}

.bidir-text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  margin: 0 0 14px;
}

.bidir-list {
  list-style: none;
  margin: 0 0 16px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.bidir-list li {
  font-size: var(--text-sm);
  color: var(--color-text);
  padding-left: 16px;
  position: relative;
}

.bidir-list li::before {
  content: '✓';
  color: var(--color-primary);
  position: absolute;
  left: 0;
  font-weight: var(--font-bold);
}

.bidir-price {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--color-primary);
}

.bidir-price--muted { color: var(--color-text-muted); }


/* ===== SECTION 3: E-E-A-T ===== */
.eeat-section {
  background: #1e3a8a;
  padding: 64px 0;
}

@media (max-width: 767px) {
  .eeat-section { padding: 40px 0; }
}

.eeat-grid {
  display: flex;
  flex-direction: column-reverse;
  gap: 40px;
}

@media (min-width: 1024px) {
  .eeat-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 64px;
    align-items: start;
  }
}

.eeat-label {
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
}

.eeat-h2 {
  font-size: var(--text-3xl);
  font-weight: var(--font-black);
  color: white;
  margin: 0 0 16px;
  line-height: var(--leading-tight);
}

.eeat-text {
  font-size: var(--text-base);
  color: rgba(255, 255, 255, 0.85);
  line-height: var(--leading-relaxed);
  margin: 0 0 24px;
}

.eeat-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.eeat-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.9);
  line-height: var(--leading-normal);
}

.eeat-list li svg { flex-shrink: 0; margin-top: 2px; }

.eeat-list strong { color: white; }

/* Register card */
.register-card {
  background: white;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}

.register-photo-wrap {
  position: relative;
  aspect-ratio: 3/2;
  overflow: hidden;
}

.register-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
}

.register-photo-chip {
  position: absolute;
  bottom: 12px;
  right: 12px;
  background: var(--color-primary);
  color: white;
  border-radius: 16px;
  padding: 5px 12px;
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  display: flex;
  align-items: center;
  gap: 5px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.register-card-body {
  padding: 14px 18px 18px;
}

.register-label {
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 8px;
}

.register-name {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--color-text);
  margin: 0 0 4px;
}

.register-cred {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
  margin: 0 0 6px;
}

.register-nr {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin: 0 0 6px;
}

.register-langs {
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--font-medium);
  margin: 0;
}

.register-divider {
  height: 1px;
  background: var(--color-border);
  margin: 12px 0;
}

.register-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--font-semibold);
  text-decoration: none;
  background: var(--color-primary-light);
  border: 1.5px solid var(--color-primary);
  border-radius: 8px;
  padding: 9px 14px;
  transition: all 0.15s ease;
}

.register-link:hover {
  background: var(--color-primary);
  color: white;
}

/* ===== SECTION 4: DOCS ===== */
.docs-section {
  background: var(--color-bg);
  padding: var(--section-py) 0;
}

.docs-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

@media (min-width: 640px) {
  .docs-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .docs-grid { grid-template-columns: repeat(4, 1fr); }
}

.doc-card-item {
  display: flex;
  flex-direction: column;
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 16px;
  text-decoration: none;
  color: inherit;
  transition: all 0.2s ease;
}

.doc-card-item:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-card-hover);
  transform: translateY(-2px);
}

.doc-card-item--all {
  background: var(--color-primary-light);
  border: 2px dashed var(--color-primary);
  align-items: center;
  justify-content: center;
  gap: 10px;
  min-height: 120px;
}

.doc-all-text {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--color-primary);
  text-align: center;
}

.doc-card-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.doc-card-icon-wrap {
  width: 32px;
  height: 32px;
  background: var(--color-primary-light);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.doc-card-badge {
  font-size: 10px;
  font-weight: var(--font-semibold);
  background: #FEF3C7;
  color: #92400E;
  border-radius: 4px;
  padding: 2px 6px;
}

.doc-card-price {
  margin-left: auto;
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--color-primary);
}

.doc-card-name {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--color-text);
  margin: 0 0 4px;
}

.doc-card-ua {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  font-style: italic;
  margin-bottom: 6px;
}

.doc-card-usage {
  font-size: var(--text-xs);
  color: var(--color-primary);
  line-height: var(--leading-normal);
  flex: 1;
  margin-bottom: 10px;
}

.doc-card-link {
  font-size: var(--text-xs);
  color: var(--color-primary);
  font-weight: var(--font-semibold);
  margin-top: auto;
}

.docs-note {
  text-align: center;
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

.docs-note-link {
  color: var(--color-primary);
  font-weight: var(--font-semibold);
  text-decoration: none;
}

.docs-note-link:hover { text-decoration: underline; }

/* Zeilenpreis card */
.docs-zeilen-card {
  background: var(--color-primary-light);
  border: 2px solid var(--color-primary);
  border-radius: 16px;
  padding: 22px 28px;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.docs-zeilen-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.docs-zeilen-badge {
  display: inline-block;
  background: var(--color-primary);
  color: white;
  font-size: 10px;
  font-weight: var(--font-bold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 6px;
}

.docs-zeilen-price {
  font-size: var(--text-xl);
  font-weight: var(--font-black);
  color: var(--color-primary);
}

.docs-zeilen-h3 {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--color-text);
  margin: 0;
}

.docs-zeilen-docs {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.docs-zeilen-doc {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--color-primary);
  background: white;
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid var(--color-primary);
}


.docs-zeilen-text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  margin: 0;
}

.docs-zeilen-cta {
  display: inline-block;
  background: var(--color-primary);
  color: white;
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  padding: 10px 20px;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s ease;
  align-self: flex-start;
}

.docs-zeilen-cta:hover { background: var(--color-primary-dark); }

.apostille-hint {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  background: #FEF3C7;
  border-left: 3px solid #F59E0B;
  border-radius: 8px;
  padding: 16px 18px;
  margin-top: 16px;
}
.apostille-hint svg { flex-shrink: 0; margin-top: 2px; }
.apostille-hint p {
  font-size: var(--text-sm);
  color: #1c1917;
  line-height: 1.6;
  margin: 0 0 6px;
}
.apostille-hint-note {
  color: #78716c !important;
  font-size: 0.8125rem;
  font-style: italic;
}
.apostille-hint a {
  color: #92400e;
  font-weight: 600;
  font-size: var(--text-sm);
  text-decoration: none;
}
.apostille-hint a:hover { text-decoration: underline; }

/* ===== SECTION 6: SITUATIONEN ===== */
.situations-section {
  background: var(--color-bg);
  padding: var(--section-py) 0;
}

.situations-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

@media (min-width: 640px) {
  .situations-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .situations-grid { grid-template-columns: repeat(3, 1fr); }
}

.situation-card {
  background: var(--color-bg-soft);
  border: 1px solid var(--color-border);
  border-radius: 16px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  transition: all 0.2s ease;
}

.situation-card:hover {
  background: white;
  border-color: var(--color-primary);
  transform: translateY(-2px);
}

.situation-icon-wrap {
  width: 44px;
  height: 44px;
  background: var(--color-primary-light);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
}

.situation-h3 {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--color-text);
  margin: 0 0 10px;
}

.situation-text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  margin: 0 0 14px;
}

.situation-list {
  list-style: none;
  margin: 0 0 16px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}

.situation-list li {
  font-size: var(--text-sm);
  color: var(--color-text);
  padding-left: 18px;
  position: relative;
}

.situation-list li::before {
  content: '✓';
  color: var(--color-primary);
  position: absolute;
  left: 0;
  font-weight: var(--font-bold);
  font-size: var(--text-xs);
}

.situation-link {
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--font-semibold);
  text-decoration: none;
  margin-top: auto;
}

.situation-link:hover { text-decoration: underline; }

/* ===== SECTION 7: JOBCENTER ===== */
.jobcenter-section {
  background: #FFFBEB;
  border-top: 3px solid #F59E0B;
  padding: var(--section-py) 0;
}

.jobcenter-badge {
  display: inline-block;
  background: #FEF3C7;
  color: #92400E;
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 12px;
  margin-bottom: 16px;
}

.jobcenter-h2 {
  font-size: var(--text-3xl);
