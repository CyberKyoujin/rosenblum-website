---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';
import languages from '../data/languages.json';

const langCount = languages.length;

const timeline = [
  {
    year: '2016',
    title: 'Gründung in Osnabrück',
    text: 'Oleg Rosenblum startet als vereidigter Übersetzer für Ukrainisch und Russisch.',
  },
  {
    year: '2020',
    title: '1.000 Kunden',
    text: 'Das Büro wächst über die Region hinaus – deutschlandweite Nachfrage.',
  },
  {
    year: '2022',
    title: 'Online-Bestellsystem',
    text: 'Dokumente hochladen, Angebot erhalten, Übersetzung per Post – vollständig digital.',
  },
  {
    year: '2024',
    title: '5.000 Kunden · 10.000 Übersetzungen',
    text: 'Ein Netzwerk vereidigter Übersetzer betreut Privatkunden, Kanzleien und Behörden.',
  },
  {
    year: '2026',
    title: `${langCount} Sprachen · deutschlandweiter Versand`,
    text: 'Ein Ansprechpartner für beglaubigte Übersetzungen in ganz Deutschland.',
  },
];

const team = [
  {
    name: 'Oleg Rosenblum',
    role: 'Gründer & vereidigter Übersetzer',
    text: 'Vom Landgericht Hannover allgemein beeidigter Dolmetscher und ermächtigter Übersetzer für die russische und ukrainische Sprache.',
    photo: '/media/oleg.jpg',
  },
  {
    name: 'Elana Rosenblum',
    role: 'Kundenbetreuung & Finanzen',
    text: 'Erste Ansprechpartnerin für Anfragen, Angebote und Rechnungen – sie hält Kommunikation und Abläufe zuverlässig am Laufen.',
    initials: 'ER',
  },
  {
    name: 'Denys Novakov',
    role: 'Digital Operations & IT',
    text: 'Verantwortlich für das Online-Bestellsystem und den digitalen Workflow – damit Hochladen, Angebot und Versand reibungslos funktionieren.',
    initials: 'DN',
  },
];

const stats = [
  { prefix: 'Ø ', target: 28, suffix: ' Min.', label: 'bis zum Kostenvoranschlag' },
  { target: 97, suffix: '%', label: 'Annahmequote – keine Nachfragen der Behörden' },
  { target: 100, suffix: '%', label: 'Online – kein Bürobesuch nötig' },
  { target: 1, suffix: '', label: 'vereidigter Übersetzer – persönliche Verantwortung für jede Übersetzung' },
  { target: 3, suffix: '', label: 'Länder – Deutschland, Ukraine, Österreich' },
  { target: 0, suffix: ' €', label: 'Kostenvoranschlag – immer kostenlos & unverbindlich' },
];

const benefits = [
  {
    icon: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>',
    title: 'Vereidigter Übersetzer',
    text: 'Alle Übersetzungen tragen ein offizielles Amtssiegel und werden von deutschen Behörden anerkannt.',
  },
  {
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    title: `${langCount} Sprachen – ein Ansprechpartner`,
    text: 'Sie brauchen nicht für jede Sprache ein neues Büro zu suchen. Wir koordinieren alles für Sie.',
  },
  {
    icon: '<path d="M3 11V6a2 2 0 0 1 2-2h5l11 11-7 7L3 11z"/><circle cx="8.5" cy="8.5" r="1.5"/>',
    title: 'Transparente Festpreise',
    text: 'Keine versteckten Kosten. Sie kennen den Preis, bevor Sie bestellen.',
  },
  {
    icon: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
    title: 'Online-Bestellung',
    text: 'Dokument hochladen, Angebot erhalten, Übersetzung per Post. Alles digital.',
  },
  {
    icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/>',
    title: 'Kostenübernahme durch Jobcenter',
    text: 'Wir helfen beim Antrag. Kostenvoranschlag in 30 Minuten.',
    href: '/preise/#jobcenter',
  },
  {
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
    title: 'Express in 24 Stunden',
    text: 'Dringende Übersetzung? Wir liefern innerhalb eines Werktages.',
  },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Oleg Rosenblum',
  jobTitle: 'Vereidigter Übersetzer',
  worksFor: {
    '@type': 'LocalBusiness',
    name: 'Rosenblum Übersetzungsbüro',
  },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'Vereidigter Übersetzer',
    recognizedBy: {
      '@type': 'Organization',
      name: 'Landgericht Hannover',
    },
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Osnabrück',
    addressCountry: 'DE',
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Rosenblum Übersetzungsbüro',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Alte Poststraße 25',
    addressLocality: 'Osnabrück',
    postalCode: '49074',
    addressCountry: 'DE',
  },
  telephone: '+4917624137205',
  email: 'rosenblum.uebersetzungsbuero@gmail.com',
  openingHours: 'Mo-Fr 09:00-18:00',
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 52.2715,
    longitude: 8.048,
  },
  url: 'https://rosenblum-uebersetzungen.de',
  priceRange: 'ab €30,30',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '50',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Über uns', item: 'https://rosenblum-uebersetzungen.de/ueber-uns/' },
  ],
};
---

<BaseLayout
  title="Über uns – Rosenblum Übersetzungsbüro Osnabrück"
  description="Rosenblum Übersetzungsbüro – seit 2016 in Osnabrück. Oleg Rosenblum, vereidigter Übersetzer am Landgericht Hannover. 10.000+ beglaubigte Übersetzungen, deutschlandweit."
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/ueber-uns/"
  schema={[personSchema, localBusinessSchema, breadcrumbSchema]}
>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 1 · HERO
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-grid">
      <div class="hero-text-col">
        <div class="section-label"><span class="line"></span>ÜBER UNS</div>

        <h1 class="hero-h1">
          Die Menschen hinter{' '}<br />
          <span class="hero-accent">Ihren Übersetzungen.</span>
        </h1>

        <p class="hero-sub">
          Seit 2016 übersetzen wir Dokumente – persönlich, zuverlässig, deutschlandweit.
        </p>

        <div class="hero-ctas">
          <a href="/kontakt" class="btn-primary btn-lg">Kontaktieren Sie uns</a>
          <a href="#geschichte" class="hero-link">Unsere Geschichte ↓</a>
        </div>

        <ul class="trust-items" aria-label="Vertrauenssiegel">
          <li class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Vom Landgericht Hannover vereidigt
          </li>
          <li class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Von deutschen Behörden anerkannt
          </li>
        </ul>

        <div class="hero-stats" aria-label="Kennzahlen">
          <div class="hero-stat"><span class="hero-stat-value">8+</span><span class="hero-stat-label">Jahre Erfahrung</span></div>
          <div class="hero-stat"><span class="hero-stat-value">10.000+</span><span class="hero-stat-label">Übersetzungen</span></div>
          <div class="hero-stat"><span class="hero-stat-value">5.000+</span><span class="hero-stat-label">Zufriedene Kunden</span></div>
          <div class="hero-stat"><span class="hero-stat-value">{langCount}</span><span class="hero-stat-label">Sprachen</span></div>
        </div>
      </div>

      <div class="hero-photos">
        <img src="/media/oleg.jpg" alt="Oleg Rosenblum, Gründer von Rosenblum Übersetzungsbüro" class="photo-main" />

        <div class="photo-secondary" aria-hidden="true">
          <span class="photo-secondary-text">FOTO: Oleg bei der Arbeit</span>
        </div>

        <div class="hero-signature-card">
          <img src="/media/oleg.jpg" alt="" class="signature-avatar" />
          <div>
            <div class="signature-name">Oleg Rosenblum</div>
            <div class="signature-role">Gründer & vereidigter Übersetzer</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · UNSERE GESCHICHTE
  ════════════════════════════════════════════════ -->
  <section class="geschichte" id="geschichte" aria-labelledby="geschichte-h2">
    <div class="container geschichte-grid">
      <div class="geschichte-text">
        <div class="section-label"><span class="line"></span>UNSERE GESCHICHTE</div>
        <h2 id="geschichte-h2" class="section-h2">Von Osnabrück aus für ganz Deutschland</h2>

        <p class="geschichte-p">
          Rosenblum Übersetzungsbüro wurde <strong>2016 von Oleg Rosenblum</strong> in
          Osnabrück gegründet. Als vom Landgericht Hannover vereidigter Übersetzer für
          Ukrainisch und Russisch begann er mit beglaubigten Übersetzungen für die
          ukrainische und russische Gemeinschaft in Niedersachsen.
        </p>
        <p class="geschichte-p">
          Was als Ein-Mann-Büro begann, ist heute ein Übersetzungsbüro mit einem{' '}
          <strong>Netzwerk vereidigter Übersetzer für {langCount} Sprachen</strong>. Über
          5.000 Kunden vertrauen uns – von Privatpersonen über Anwaltskanzleien bis hin
          zu Behörden.
        </p>

        <div class="geschichte-signature">
          <img src="/media/oleg.jpg" alt="" class="geschichte-avatar" />
          <div>
            <div class="signature-name">Oleg Rosenblum</div>
            <div class="signature-role-muted">Gründer, Rosenblum Übersetzungsbüro</div>
          </div>
        </div>
      </div>

      <ol class="timeline" role="list">
        {timeline.map((item) => (
          <li class="timeline-item" role="listitem">
            <span class="timeline-dot" aria-hidden="true"></span>
            <span class="timeline-year">{item.year}</span>
            <h3 class="timeline-title">{item.title}</h3>
            <p class="timeline-text">{item.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · PERSÖNLICHE WORTE VON OLEG
  ════════════════════════════════════════════════ -->
  <section class="quote-section" aria-label="Persönliche Worte von Oleg">
    <div class="container quote-container">
      <div class="quote-seal" aria-hidden="true">
        <svg width="200" height="200" viewBox="0 0 200 200">
          <circle cx="100" cy="100" r="92" fill="none" stroke="white" stroke-width="2"/>
          <circle cx="100" cy="100" r="74" fill="none" stroke="white" stroke-width="1"/>
          <text x="100" y="96" text-anchor="middle" fill="white" font-size="30" font-weight="900">O.R.</text>
          <text x="100" y="118" text-anchor="middle" fill="white" font-size="8" letter-spacing="2">VEREIDIGT · LG HANNOVER</text>
        </svg>
      </div>

      <div class="quote-mark" aria-hidden="true">&laquo;</div>

      <blockquote class="quote-text">
        Ich übersetze seit 2016. Nicht weil es mein Job ist – sondern weil ich weiß,
        was ein fehlerhafter Stempel bedeutet. Ein abgelehnter Antrag, ein verpasster
        Termin, ein Jahr Verzögerung. Jede Übersetzung trägt meine persönliche
        Unterschrift. Das ist keine Formalität – das ist meine Verantwortung.
      </blockquote>

      <div class="quote-divider"></div>

      <div class="quote-signature">
        <img src="/media/oleg.jpg" alt="" class="quote-avatar" />
        <div>
          <div class="quote-name">Oleg Rosenblum</div>
          <div class="quote-role">Gründer & vereidigter Übersetzer · Landgericht Hannover</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · UNSER TEAM
  ════════════════════════════════════════════════ -->
  <section class="team" aria-labelledby="team-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>UNSER TEAM</div>
      <h2 id="team-h2" class="section-h2">Echte Menschen, echte Verantwortung</h2>
      <p class="section-sub">
        Drei Personen sorgen dafür, dass Ihre Dokumente korrekt übersetzt und pünktlich
        geliefert werden.
      </p>

      <div class="team-grid">
        {team.map((member) => (
          <div class="team-card">
            {member.photo ? (
              <img src={member.photo} alt={member.name} class="team-photo" />
            ) : (
              <div class="team-photo team-photo-placeholder" aria-hidden="true">
                <span class="team-initials">{member.initials}</span>
                <span class="team-photo-note">FOTO FOLGT</span>
              </div>
            )}
            <div class="team-body">
              <h3 class="team-name">{member.name}</h3>
              <p class="team-role">{member.role}</p>
              <p class="team-text">{member.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 5 · ROSENBLUM IN ZAHLEN
  ════════════════════════════════════════════════ -->
  <section class="zahlen" aria-labelledby="zahlen-h2">
    <div class="container">
      <div class="zahlen-label">— ZAHLEN &amp; FAKTEN</div>
      <h2 id="zahlen-h2" class="zahlen-h2">Rosenblum in Zahlen</h2>
      <p class="zahlen-sub">Acht Jahre Arbeit, in einer Übersicht.</p>

      <div class="zahlen-grid">
        {stats.map((s) => (
          <div class="zahlen-card">
            <div class="zahlen-value">
              {s.prefix && <span class="zahlen-prefix">{s.prefix}</span>}
              <span class="zahlen-num" data-target={s.target} data-suffix={s.suffix} aria-live="off">0</span>
            </div>
            <p class="zahlen-card-label">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 6 · WORAUF SIE SICH VERLASSEN KÖNNEN
  ════════════════════════════════════════════════ -->
  <section class="warum" aria-labelledby="warum-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>WARUM ROSENBLUM?</div>
      <h2 id="warum-h2" class="section-h2">Worauf Sie sich verlassen können</h2>
      <p class="section-sub">Konkrete Vorteile – keine leeren Versprechen.</p>

      <div class="benefits-grid">
        {benefits.map((b) => {
          const Tag = b.href ? 'a' : 'div';
          return (
            <Tag class="benefit-card" {...(b.href ? { href: b.href } : {})}>
              <div class="benefit-icon" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${b.icon}</svg>`} />
              <h3 class="benefit-title">{b.title}</h3>
              <p class="benefit-text">{b.text}</p>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 7 · UNSER STANDORT
  ════════════════════════════════════════════════ -->
  <section class="standort" aria-labelledby="standort-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>UNSER STANDORT</div>
      <h2 id="standort-h2" class="section-h2">Unser Büro in Osnabrück</h2>

      <div class="standort-grid">
        <div class="office-photo-placeholder" aria-hidden="true">
          <span class="office-photo-text">FOTO: Büro-Eingang</span>
          <span class="office-photo-sub">Rosenblum Übersetzungsbüro · ohne Nachbar-Schild</span>
        </div>

        <div class="standort-right">
          <div class="contact-card">
            <h3 class="contact-card-h3">Kontakt &amp; Öffnungszeiten</h3>

            <div class="contact-row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <div class="contact-line1">Alte Poststraße 25</div>
                <div class="contact-line2">49074 Osnabrück</div>
              </div>
            </div>
            <div class="contact-row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <div class="contact-line1">0176 24137205</div>
                <div class="contact-line2">Mobil &amp; WhatsApp</div>
              </div>
            </div>
            <div class="contact-row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
              <div>
                <div class="contact-line1 contact-email">rosenblum.uebersetzungsbuero@gmail.com</div>
                <div class="contact-line2">Antwort meist am selben Tag</div>
              </div>
            </div>
            <div class="contact-row">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <div class="contact-line1">Mo–Fr: 9:00–18:00 Uhr</div>
                <div class="contact-line2">Termine nach Vereinbarung</div>
              </div>
            </div>
          </div>

          <div id="map" class="map" role="img" aria-label="Standort Rosenblum Übersetzungsbüro in Osnabrück"></div>
        </div>
      </div>

      <div class="standort-info">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <p>
          Unser Büro befindet sich in Osnabrück – wir arbeiten jedoch
          <strong> deutschlandweit</strong>. Ihre Dokumente können Sie bequem online
          einreichen und erhalten die fertige Übersetzung per Post.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 8 · FINAL CTA
  ════════════════════════════════════════════════ -->
  <section class="final-cta-wrap">
    <div class="container final-cta">
      <h2 class="final-cta-h2">Haben Sie Fragen oder benötigen Sie ein Angebot?</h2>
      <p class="final-cta-text">
        Schreiben Sie uns – wir melden uns persönlich und erstellen Ihnen einen
        unverbindlichen Kostenvoranschlag.
      </p>
      <div class="final-cta-buttons">
        <a href="/kontakt" class="final-cta-primary">Kontaktieren Sie uns</a>
        <a href="/app/bestellen" class="final-cta-secondary">Kostenvoranschlag anfordern</a>
      </div>
    </div>
  </section>

  <StickyBar />

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
  <script is:inline>
    const map = L.map('map').setView([52.2715, 8.048], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
    }).addTo(map);
    L.marker([52.2715, 8.048])
      .addTo(map)
      .bindPopup('Rosenblum Übersetzungsbüro')
      .openPopup();
  </script>
</BaseLayout>

<script>
  function animateCounter(el: HTMLElement, target: number, suffix: string, duration = 1500) {
    const start = performance.now();
    requestAnimationFrame(function update(time) {
      const progress = Math.min((time - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(target * eased);
      el.textContent = progress < 1 ? String(current) : `${target}${suffix}`;
      if (progress < 1) requestAnimationFrame(update);
    });
  }

  const zahlenGrid = document.querySelector('.zahlen-grid');
  const nums = document.querySelectorAll<HTMLElement>('.zahlen-num');

  if (zahlenGrid && nums.length) {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            nums.forEach((el) => {
              const target = parseInt(el.getAttribute('data-target') ?? '0', 10);
              const suffix = el.getAttribute('data-suffix') ?? '';
              animateCounter(el, target, suffix);
            });
            obs.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(zahlenGrid);
  }
</script>

