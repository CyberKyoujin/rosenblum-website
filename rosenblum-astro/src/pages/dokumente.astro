---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';

const icons: Record<string, string> = {
  document: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>',
  idcard: '<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>',
  graduation: '<path d="M22 10 12 5 2 10l10 5 10-5z"/><path d="M6 12.5V17c3 2.5 9 2.5 12 0v-4.5"/>',
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  clipboard: '<rect x="7" y="3" width="10" height="4" rx="1"/><path d="M7 5H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1"/><line x1="8" y1="11" x2="16" y2="11"/><line x1="8" y1="15" x2="16" y2="15"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  stamp: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
  scale: '<path d="M12 3v18"/><path d="M5 7 2 14a4 4 0 0 0 6 0z"/><path d="M19 7l-3 7a4 4 0 0 0 6 0z"/><path d="M5 7h14"/><path d="M3 21h18"/>',
  filehearth: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 17.3s-2.3-1.5-2.3-3.1c0-.8.6-1.4 1.3-1.4.5 0 .9.3 1 .6.1-.3.5-.6 1-.6.7 0 1.3.6 1.3 1.4 0 1.6-2.3 3.1-2.3 3.1z"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  mappin: '<path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  heart: '<path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z"/>',
  check: '<polyline points="20 6 9 17 4 12"/>',
};

const heroQuickNav = [
  { icon: 'document', label: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
  { icon: 'idcard', label: 'Führerschein', href: '/beglaubigte-uebersetzung/fuehrerschein' },
  { icon: 'graduation', label: 'Diplom', href: '/beglaubigte-uebersetzung/diplom' },
  { icon: 'document', label: 'Heiratsurkunde', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
  { icon: 'idcard', label: 'Pass / Ausweis', href: '/beglaubigte-uebersetzung/pass' },
  { icon: 'home', label: 'Meldebescheinigung', href: '/beglaubigte-uebersetzung/meldebescheinigung' },
  { icon: 'graduation', label: 'Zeugnis', href: '/beglaubigte-uebersetzung/diplom' },
  { icon: 'star', label: 'Apostille', href: '/apostille' },
];

const docGroups = [
  {
    icon: 'filehearth',
    title: 'Personenstandsurkunden',
    sub: 'Standesamtliche Urkunden für Behörden und Einbürgerung',
    docs: [
      { icon: 'document', name: 'Geburtsurkunde', price: '35,30 €', usage: 'Für Einbürgerung, Standesamt, Kindergeld', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { icon: 'document', name: 'Heiratsurkunde', price: '35,30 €', usage: 'Für Familienzusammenführung, Namensänderung', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
      { icon: 'document', name: 'Sterbeurkunde', price: '35,30 €', usage: 'Für Erbschaft, Rentenantrag, Versicherung', href: '/beglaubigte-uebersetzung/sterbeurkunde' },
      { icon: 'document', name: 'Scheidungsurkunde', price: '35,30 €', usage: 'Für Wiederheirat, Namensänderung', href: '/beglaubigte-uebersetzung/scheidungsurkunde' },
    ],
  },
  {
    icon: 'graduation',
    title: 'Bildungsdokumente',
    sub: 'Schulzeugnisse, Diplome und akademische Nachweise',
    docs: [
      { icon: 'graduation', name: 'Diplom (ohne Notenanlage)', price: '35,30 €', usage: 'Für Berufsanerkennung, Anabin-Datenbank', href: '/beglaubigte-uebersetzung/diplom' },
      { icon: 'graduation', name: 'Reifezeugnis + Anlage', price: '78,90 €', usage: 'Für Hochschulzulassung, Berufsanerkennung', href: '/beglaubigte-uebersetzung/diplom' },
      { icon: 'graduation', name: 'Reifezeugnis (ohne Anlage)', price: '35,30 €', usage: 'Für einfache Nachweise', href: '/beglaubigte-uebersetzung/diplom' },
      { icon: 'clipboard', name: 'Bescheinigungen / Zertifikate', price: '35,30 €', usage: 'Für Weiterbildungen bis 1 Seite', href: '/beglaubigte-uebersetzung/zertifikat' },
    ],
  },
  {
    icon: 'home',
    title: 'Behördliche Dokumente',
    sub: 'Amtliche Dokumente für Ausländerbehörde und Behörden',
    docs: [
      { icon: 'idcard', name: 'Führerschein', price: '30,30 €', usage: 'Für Führerscheinumtausch', href: '/beglaubigte-uebersetzung/fuehrerschein', badge: 'Günstigster Einstieg' },
      { icon: 'idcard', name: 'Pass / Ausweis', price: '35,30 €', usage: 'Für Ausländerbehörde, Identitätsnachweis', href: '/beglaubigte-uebersetzung/pass' },
      { icon: 'home', name: 'Aufenthaltserlaubnis', price: '35,30 €', usage: 'Für Verlängerung, Familienzusammenführung', href: '/beglaubigte-uebersetzung/aufenthaltserlaubnis' },
      { icon: 'shield', name: 'Führungszeugnis', price: '35,30 €', usage: 'Für Arbeitgeber, Behörden', href: '/beglaubigte-uebersetzung/fuehrungszeugnis' },
      { icon: 'home', name: 'Meldebescheinigung', price: '35,30 €', usage: 'Für Behörden, Banken', href: '/beglaubigte-uebersetzung/meldebescheinigung' },
    ],
  },
  {
    icon: 'scale',
    title: 'Rechtsdokumente',
    sub: 'Gerichtliche und notarielle Unterlagen',
    docs: [
      { icon: 'scale', name: 'Gerichtsentscheidung', price: 'Zeilenpreis', usage: 'Urteile, Beschlüsse', href: '/beglaubigte-uebersetzung/gerichtsentscheidung' },
      { icon: 'scale', name: 'Vollmacht', price: '35,30 €', usage: 'Für notarielle Zwecke', href: '/beglaubigte-uebersetzung/vollmacht' },
      { icon: 'scale', name: 'Vertrag', price: 'Zeilenpreis', usage: 'Kauf-, Miet-, Arbeitsverträge', href: '/beglaubigte-uebersetzung/vertrag' },
    ],
  },
];

const situations = [
  {
    icon: 'star',
    title: 'Einbürgerung',
    sub: 'Für den Einbürgerungsantrag benötigen Sie in der Regel:',
    checklist: [
      { text: 'Geburtsurkunde (beglaubigte Übersetzung)', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { text: 'Heiratsurkunde (falls verheiratet)', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
      { text: 'Ggf. Scheidungsurteil' },
      { text: 'Ggf. Apostille auf die Übersetzung' },
    ],
    price: '70,60 €',
    ctaText: 'Jetzt bestellen →',
    ctaHref: '/app/bestellen?doc=einbuergerung',
  },
  {
    icon: 'mappin',
    title: 'Aufenthaltstitel & ABH',
    sub: 'Für die Ausländerbehörde:',
    checklist: [
      { text: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { text: 'Reisepass (Datenseite)', href: '/beglaubigte-uebersetzung/pass' },
      { text: 'Heiratsurkunde (falls verheiratet)', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
      { text: 'Ggf. Meldebescheinigung' },
    ],
    price: '35,30 €',
    ctaText: 'Jetzt bestellen →',
    ctaHref: '/app/bestellen?doc=aufenthaltstitel',
  },
  {
    icon: 'graduation',
    title: 'Hochschule / Berufsanerkennung',
    sub: 'Für Hochschulzulassung oder Anabin-Prüfung:',
    checklist: [
      { text: 'Reifezeugnis mit Anlage (beglaubigte Übersetzung)', href: '/beglaubigte-uebersetzung/diplom' },
      { text: 'Ggf. Diplom' },
      { text: 'Ggf. Apostille' },
    ],
    price: '78,90 €',
    ctaText: 'Jetzt bestellen →',
    ctaHref: '/app/bestellen?doc=hochschule',
  },
  {
    icon: 'briefcase',
    title: 'Jobcenter / Berufsabschluss',
    sub: 'Für Anerkennung ausländischer Berufsabschlüsse:',
    checklist: [
      { text: 'Arbeitsbuch (Übersetzung pro Zeile)' },
      { text: 'Diplom oder Fachzeugnis', href: '/beglaubigte-uebersetzung/diplom' },
      { text: 'Kostenvoranschlag für Jobcenter (kostenlos)' },
    ],
    price: '1,40 €/Zeile',
    ctaText: 'Kostenvoranschlag – kostenlos →',
    ctaHref: '/preise/#jobcenter',
  },
  {
    icon: 'heart',
    title: 'Heirat / Standesamt',
    sub: 'Für die Eheschließung beim Standesamt:',
    checklist: [
      { text: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { text: 'Ledigkeitsbescheinigung' },
      { text: 'Ggf. Scheidungsurteil' },
      { text: 'Ggf. Apostille auf Übersetzung' },
    ],
    price: '70,60 €',
    ctaText: 'Jetzt bestellen →',
    ctaHref: '/app/bestellen?doc=heirat',
  },
];

const timelineGroups = [
  {
    std: 72, exp: 24, festpreis: true,
    docs: ['Geburtsurkunde', 'Heiratsurkunde', 'Sterbeurkunde', 'Scheidungsurkunde', 'Führerschein', 'Pass / Ausweis', 'Meldebescheinigung', 'Führungszeugnis', 'Aufenthaltserlaubnis'],
  },
  {
    std: 120, exp: 72, festpreis: false,
    docs: ['Diplom (ohne Notenanlage)', 'Reifezeugnis + Anlage'],
  },
  {
    std: 168, exp: 120, festpreis: false,
    docs: ['Gerichtsentscheidung', 'Arbeitsbuch', 'Vertrag'],
  },
];

const faqs = [
  {
    q: 'Welche Dokumente können beglaubigt übersetzt werden?',
    a: 'Wir übersetzen alle gängigen ukrainischen und russischen Dokumente: Personenstandsurkunden (Geburtsurkunde, Heiratsurkunde, Sterbeurkunde), Bildungsdokumente (Diplom, Reifezeugnis), Behördliche Dokumente (Führerschein, Pass, Aufenthaltserlaubnis) sowie Rechtsdokumente. Für Dokumente die nicht in unserer Liste sind erstellen wir ein individuelles Angebot.',
  },
  {
    q: 'Welche Dokumente brauche ich für die Einbürgerung?',
    a: 'Für den Einbürgerungsantrag benötigen Sie in der Regel eine beglaubigte Übersetzung Ihrer Geburtsurkunde. Falls verheiratet auch die Heiratsurkunde, bei Scheidung das Scheidungsurteil. Die genauen Anforderungen hängen von Ihrer Ausländerbehörde ab – wir beraten Sie gerne.',
  },
  {
    q: 'Welche Dokumente brauche ich für die Ausländerbehörde?',
    a: 'Die Ausländerbehörde verlangt typischerweise beglaubigte Übersetzungen von Geburtsurkunde, Reisepass-Datenseite und Heiratsurkunde (falls verheiratet). Bei Verlängerung des Aufenthaltstitels können weitere Dokumente erforderlich sein.',
  },
  {
    q: 'Welche Dokumente brauche ich für Uni-Assist?',
    a: 'Für die Hochschulzulassung über Uni-Assist benötigen Sie eine beglaubigte Übersetzung Ihres Reifezeugnisses mit Notenanlage (78,90 €). Bei ausländischen Diplomen zusätzlich eine Übersetzung des Diploms. Alle Übersetzungen werden von Uni-Assist anerkannt.',
  },
  {
    q: 'Muss ich das Originaldokument einsenden?',
    a: 'Nein. Ein Foto oder Scan Ihres Dokuments reicht für die Übersetzung aus. Das Original müssen Sie nur dann einreichen, wenn die Behörde ausdrücklich verlangt, dass die Übersetzung am Original befestigt wird – das teilen wir Ihnen im Kostenvoranschlag mit.',
  },
  {
    q: 'Wie lange dauert eine beglaubigte Übersetzung?',
    a: 'Standarddokumente wie Geburtsurkunde oder Führerschein übersetzen wir in 72 Stunden. Mit Express-Option in 24 Stunden. Umfangreichere Dokumente wie Diplome oder Gerichtsurteile benötigen 5–7 Werktage. Die fertige Übersetzung erhalten Sie per Post.',
  },
  {
    q: 'Werden die Übersetzungen von allen deutschen Behörden akzeptiert?',
    a: 'Ja. Alle unsere Übersetzungen werden von Oleg Rosenblum erstellt – vereidigter Übersetzer am Landgericht Hannover. Die Übersetzungen sind mit Siegel und handschriftlicher Unterschrift versehen und werden deutschlandweit von allen Behörden, Gerichten und Hochschulen anerkannt.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Dokumente', item: 'https://rosenblum-uebersetzungen.de/dokumente/' },
  ],
};
---

<BaseLayout
  title="Dokumente übersetzen lassen – beglaubigt & rechtsgültig | Rosenblum"
  description="Beglaubigte Übersetzungen für Geburtsurkunde, Führerschein, Diplom, Heiratsurkunde und 20+ weitere Dokumente. Ab 30,30 €, 72h Lieferzeit. Vereidigter Übersetzer – deutschlandweit anerkannt."
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/dokumente/"
  schema={[faqSchema, breadcrumbSchema]}
>
  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 1 · HERO
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-grid">
      <div class="hero-top">
        <div class="hero-badge">📄 BEGLAUBIGTE ÜBERSETZUNGEN</div>

        <h1 class="hero-h1">
          Welche Dokumente<br />
          <span class="hero-accent">übersetzen wir?</span>
        </h1>

        <p class="hero-sub">
          Beglaubigte Übersetzungen für alle gängigen ukrainischen und
          russischen Dokumente – anerkannt bei deutschen Behörden, Gerichten
          und Hochschulen.
        </p>
      </div>

      <div class="quicknav-grid">
        {heroQuickNav.map((item) => (
          <a href={item.href} class="quicknav-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[item.icon]} />
            <span class="quicknav-label">{item.label}</span>
          </a>
        ))}
        <a href="#dokumente-liste" class="quicknav-card quicknav-more">+12 weitere Dokumente</a>
      </div>

      <div class="hero-bottom">
        <div class="hero-pills">
          <span class="hero-pill">📋 20+ Dokumenttypen</span>
          <span class="hero-pill">⚡ Ab 30,30 € · 72h Lieferzeit</span>
        </div>

        <div class="hero-ctas">
          <a href="/app/bestellen" class="btn-primary btn-lg hero-cta">Dokument einsenden →</a>
          <a href="#dokumente-liste" class="hero-link">Zur Dokumentliste →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · ALLE DOKUMENTE IM ÜBERBLICK
  ════════════════════════════════════════════════ -->
  <section class="dokumente-section" id="dokumente-liste" aria-labelledby="dokumente-h2">
    <div class="container">
      <h2 id="dokumente-h2" class="section-h2 centered">Alle Dokumente im Überblick</h2>
      <p class="section-sub centered">Festpreise inkl. MwSt. · Klicken Sie auf ein Dokument um zu bestellen</p>

      {docGroups.map((group) => (
        <div class="doc-group">
          <div class="doc-group-header">
            <div class="doc-group-icon" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icons[group.icon]}</svg>`} />
            <div>
              <h3 class="doc-group-title">{group.title}</h3>
              <p class="doc-group-sub">{group.sub}</p>
            </div>
          </div>

          <div class="doc-cards-grid">
            {group.docs.map((doc) => (
              <a href={doc.href} class="doc-card">
                {doc.badge && <span class="doc-badge">{doc.badge}</span>}
                <span class="doc-card-price">{doc.price}</span>
                <span class="doc-card-icon" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icons[doc.icon]}</svg>`} />
                <h4 class="doc-card-name">{doc.name}</h4>
                <p class="doc-card-usage">{doc.usage}</p>
                <span class="doc-card-link">→ Jetzt bestellen</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · IHR DOKUMENT IST NICHT DABEI?
  ════════════════════════════════════════════════ -->
  <section class="notlisted-section">
    <div class="container notlisted-grid">
      <div class="notlisted-text">
        <div class="notlisted-label">ALLE DOKUMENTE</div>
        <h2 class="notlisted-h2">Ihr Dokument ist nicht dabei?</h2>
        <p class="notlisted-body">
          Wir übersetzen alle ukrainischen und russischen Dokumente – auch
          Diplome, Gerichtsurteile, Gutachten, Impfpässe und weitere.
          Abrechnung nach Zeilen: <strong>1,30–1,80 € pro Zeile</strong> inkl. MwSt.
        </p>
        <div class="notlisted-tags">
          <span class="notlisted-tag">🎓 Diplome & Zeugnisse</span>
          <span class="notlisted-tag">⚖️ Gerichtsurteile</span>
          <span class="notlisted-tag">📋 Impfpässe & Befunde</span>
        </div>
      </div>

      <div class="notlisted-buttons">
        <a href="/app/bestellen" class="notlisted-btn-primary">Kostenvoranschlag anfordern →</a>
        <a href="https://wa.me/4917624137205" target="_blank" rel="noopener noreferrer" class="notlisted-btn-whatsapp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.87 11.92L4 20l4.2-1.1a7.9 7.9 0 0 0 3.84 1h.01a7.95 7.95 0 0 0 5.55-13.58zM12.05 18.4h-.01a6.55 6.55 0 0 1-3.36-.92l-.24-.14-2.5.65.67-2.43-.16-.25a6.6 6.6 0 0 1 10.27-8.2 6.55 6.55 0 0 1 1.93 4.67 6.6 6.6 0 0 1-6.6 6.62zm3.6-4.93c-.2-.1-1.17-.58-1.35-.64-.18-.07-.31-.1-.45.1-.13.2-.51.64-.63.77-.11.13-.23.14-.43.05-1.18-.59-1.95-1.05-2.73-2.38-.21-.35.21-.33.6-1.1.07-.13.03-.25-.02-.35-.06-.1-.5-1.2-.68-1.65-.18-.43-.37-.37-.5-.38h-.43c-.15 0-.38.06-.59.3-.2.25-.78.76-.78 1.85s.8 2.15.91 2.3c.11.13 1.55 2.37 3.78 3.32 1.87.8 2.26.65 2.66.6.4-.04 1.3-.53 1.48-1.04.18-.51.18-.95.13-1.04-.05-.1-.18-.15-.38-.25z"/></svg>
          WhatsApp: 0176 24137205
        </a>
        <a href="https://t.me/oleg_rosenblum" target="_blank" rel="noopener noreferrer" class="notlisted-btn-telegram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3L19.34 4.18c.73-.33 1.43.18 1.15 1.3l-3.21 15.1c-.22 1.02-.78 1.21-1.5.92l-4.18-3.45L9.78 18.65z"/></svg>
          Telegram schreiben
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · WAS BRAUCHE ICH WOFÜR
  ════════════════════════════════════════════════ -->
  <section class="situations-section" aria-labelledby="situations-h2">
    <div class="container">
      <h2 id="situations-h2" class="section-h2 centered">Was brauche ich wofür?</h2>
      <p class="situations-sub">Häufige Situationen – welche Übersetzungen Sie benötigen</p>

      <div class="situations-grid">
        {situations.map((s) => (
          <div class="situation-card">
            <div class="situation-icon" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icons[s.icon]}</svg>`} />
            <h3 class="situation-title">{s.title}</h3>
            <p class="situation-sub">{s.sub}</p>

            <ul class="situation-checklist">
              {s.checklist.map((item) => (
                <li class="checklist-item">
