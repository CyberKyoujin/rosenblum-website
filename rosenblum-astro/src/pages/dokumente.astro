<script>
  // ── FAQ accordion ──────────────────────────────
  document.querySelectorAll('.faq-question').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = document.getElementById(btn.getAttribute('aria-controls'));
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-question').forEach((other) => {
        other.setAttribute('aria-expanded', 'false');
        const otherBody = document.getElementById(other.getAttribute('aria-controls'));
        if (otherBody) otherBody.hidden = true;
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        if (body) body.hidden = false;
      }
    });
  });

  // ── Bearbeitungszeit timeline ──────────────────
  const docSelect = document.getElementById('doc-select');
  const expressToggle = document.getElementById('express-toggle');
  const segUeb = document.getElementById('seg-uebersetzung');
  const segPost = document.getElementById('seg-post');
  const labelUeb = document.getElementById('label-ueb');
  const totalDaysEl = document.getElementById('total-days');

  const POST_HOURS = 36;
  let isExpress = false;

  function updateTimeline() {
    const [std, exp] = (docSelect?.value ?? '72|24').split('|').map(Number);
    const uebTime = isExpress ? exp : std;
    const totalHours = 0.083 + uebTime + POST_HOURS;
    const totalDays = Math.ceil(totalHours / 24);

    if (segUeb) segUeb.style.flexGrow = String(uebTime);
    if (segPost) segPost.style.flexGrow = String(POST_HOURS);
    if (labelUeb) labelUeb.textContent = isExpress ? `${exp} Std. (Express)` : `${std} Std.`;
    if (totalDaysEl) totalDaysEl.textContent = totalDays + (totalDays === 1 ? ' Tag' : ' Tage');
  }

  docSelect?.addEventListener('change', updateTimeline);
  expressToggle?.addEventListener('click', () => {
    isExpress = !isExpress;
    expressToggle.classList.toggle('active', isExpress);
    expressToggle.setAttribute('aria-checked', String(isExpress));
    updateTimeline();
  });

  updateTimeline();
</script>

