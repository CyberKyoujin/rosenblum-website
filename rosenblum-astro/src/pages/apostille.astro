<script>
  // ── FAQ accordion ──────────────────────────────
  function setupAccordion(selector: string) {
    document.querySelectorAll(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const body = document.getElementById(btn.getAttribute('aria-controls') ?? '');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll(selector).forEach((other) => {
          other.setAttribute('aria-expanded', 'false');
          const otherBody = document.getElementById(other.getAttribute('aria-controls') ?? '');
          if (otherBody) otherBody.hidden = true;
        });
        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          if (body) body.hidden = false;
        }
      });
    });
  }
  setupAccordion('.faq-question');

  // ── Ämterkarte dropdown ────────────────────────
  const landSelect = document.getElementById('land-select') as HTMLSelectElement | null;
  const landTip = document.getElementById('land-tip');
  const landResults = document.querySelectorAll<HTMLElement>('.land-result');

  function showLand(slug: string) {
    landResults.forEach((r) => {
      r.hidden = r.getAttribute('data-slug') !== slug;
    });
    if (landTip) landTip.hidden = !!slug;
  }

  landSelect?.addEventListener('change', () => {
    const slug = landSelect.value;
    if (slug) {
      history.replaceState(null, '', `#${slug}`);
    } else {
      history.replaceState(null, '', location.pathname + location.search);
    }
    showLand(slug);
  });

  const initialSlug = location.hash.replace('#', '');
  if (initialSlug && landSelect) {
    const optionExists = Array.from(landSelect.options).some((o) => o.value === initialSlug);
    if (optionExists) {
      landSelect.value = initialSlug;
      showLand(initialSlug);
    }
  }

  // ── Decision tree state machine ────────────────
  const decisionScreens = document.querySelectorAll<HTMLElement>('.decision-screen');
  const decisionBack = document.querySelector<HTMLButtonElement>('.decision-back');
  const decisionDots = document.querySelectorAll<HTMLElement>('.decision-dot');
  const decisionHistory: string[] = [];
  let currentScreen = 'step1';

  function stepForScreen(name: string): number {
    if (name === 'step1') return 1;
    if (name === 'step2-ausland') return 2;
    return 3;
  }

  function showDecisionScreen(name: string) {
    decisionScreens.forEach((s) => {
      s.hidden = s.getAttribute('data-screen') !== name;
    });
    currentScreen = name;
    if (decisionBack) decisionBack.hidden = decisionHistory.length === 0;
    const step = stepForScreen(name);
    decisionDots.forEach((dot, i) => {
      dot.classList.toggle('active', i < step);
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.decision-option').forEach((btn) => {
    btn.addEventListener('click', () => {
      decisionHistory.push(currentScreen);
      const next = btn.getAttribute('data-next') ?? 'step1';
      showDecisionScreen(next);
    });
  });

  decisionBack?.addEventListener('click', () => {
    const prev = decisionHistory.pop();
    if (prev) showDecisionScreen(prev);
  });

  // ── Apostille scheme number markers (hover highlight) ──
  document.querySelectorAll('.scheme-marked').forEach((el) => {
    const marker = el.querySelector('.scheme-marker');
    el.addEventListener('mouseenter', () => marker?.classList.add('active'));
    el.addEventListener('mouseleave', () => marker?.classList.remove('active'));
  });
</script>

