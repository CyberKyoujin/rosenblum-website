---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';
import apostilleData from '../data/apostille-aemter.json';

const { laender } = apostilleData;

const typColors: Record<string, string> = {
  'Übersetzungen': 'typ-blue',
  'Personenstandsurkunden': 'typ-violet',
  'Öffentliche Urkunden': 'typ-green',
  'Gerichtsdokumente': 'typ-red',
};

const faqs = [
  {
    q: 'Was ist eine Apostille?',
    a: 'Eine Apostille ist ein internationaler Echtheitsnachweis, der nach dem Haager Übereinkommen von 1961 ausgestellt wird. Sie bestätigt die Echtheit der Unterschrift und des Siegels auf einem Dokument – damit es im Ausland anerkannt wird.',
  },
  {
    q: 'Wann brauche ich eine Apostille?',
    a: 'Eine Apostille brauchen Sie, wenn Ihre Dokumente in einem anderen Land verwendet werden sollen, das dem Haager Übereinkommen angehört – zum Beispiel bei Heirat in der Ukraine, Studium in den USA oder Arbeit in Großbritannien. Innerhalb der EU ist keine Apostille erforderlich.',
  },
  {
    q: 'Was kostet eine Apostille?',
    a: 'Die Apostille auf unsere Übersetzung kostet 35,00 € – das ist die offizielle Gebühr des Landgerichts Hannover. Zusammen mit der beglaubigten Übersetzung ab 30,30 € erhalten Sie das Gesamtpaket ab 65,30 €.',
  },
  {
    q: 'Wie lange dauert eine Apostille?',
    a: 'Wir beantragen die Apostille beim Landgericht Hannover innerhalb von 72 Stunden nach Fertigstellung der Übersetzung. Die Gesamtbearbeitungszeit beträgt Standard 5–7 Werktage, Express 3–4 Werktage.',
  },
  {
    q: 'Apostille auf das Original – wie beantrage ich das?',
    a: 'Die Apostille auf Ihr Originaldokument wird von der zuständigen Behörde im Ausstellungsland ausgestellt – nicht von uns. Für ukrainische Dokumente ist das das Justizministerium der Ukraine, für deutsche Dokumente das zuständige Landgericht oder Regierungspräsidium. Wir helfen Ihnen zu verstehen, welche Behörde für Ihren Fall zuständig ist.',
  },
  {
    q: 'Kann ich Apostille und Übersetzung gleichzeitig bestellen?',
    a: 'Ja – das ist unser Standard-Paket. Sie bestellen einmalig, wir erstellen die beglaubigte Übersetzung und beantragen anschließend die Apostille beim Landgericht Hannover. Alles aus einer Hand, Sie müssen sich um nichts kümmern.',
  },
  {
    q: 'Welche Länder akzeptieren eine Apostille?',
    a: 'Alle 125 Mitgliedsstaaten des Haager Übereinkommens von 1961 akzeptieren Apostillen – darunter Ukraine, USA, Großbritannien, Australien, Kanada, Japan und die meisten europäischen Länder. China, Ägypten und einige andere Länder sind keine Mitglieder – dort ist eine Legalisation erforderlich.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Apostille', item: 'https://rosenblum-uebersetzungen.de/apostille/' },
  ],
};
---

<BaseLayout
  title="Apostille – was ist das, wann brauchen Sie eine? | Rosenblum"
  description="Apostille auf Ihre beglaubigte Übersetzung ab €35,00. Was ist eine Apostille, wann brauchen Sie eine und wo beantragen? Alle Informationen + Ämter nach Bundesland."
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/apostille/"
  schema={[faqSchema, breadcrumbSchema]}
>
  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 1 · HERO
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-grid">
      <div class="hero-top">
        <div class="hero-badge" aria-label="Zertifizierung">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Apostille · Internationales Recht · Haager Übereinkommen
        </div>

        <h1 class="hero-h1">
          Apostille — wann brauchen Sie<br />
          <span class="hero-accent">eine</span> und wo beantragen?
        </h1>
      </div>

      <div class="hero-visual">
        <div class="apostille-card">
          <div class="apostille-card-title">A P O S T I L L E</div>
          <div class="apostille-card-sub">(Convention de La Haye…)</div>
          <div class="apostille-card-row"><strong>Land: BUNDESREPUBLIK DEUTSCHLAND</strong></div>
          <div class="apostille-card-line" style="width:78%"></div>
          <div class="apostille-card-line" style="width:60%"></div>
          <div class="apostille-card-footer">
            <div class="apostille-stamp-mini"></div>
            <span class="apostille-card-badge">✓ International anerkannt</span>
          </div>
        </div>
      </div>

      <div class="hero-bottom">
        <p class="hero-sub">
          Eine Apostille bestätigt die Echtheit Ihres Dokuments für das
          Ausland. Wir erklären, ob Sie eine brauchen – und stellen die
          Apostille auf Ihre Übersetzung direkt aus.
        </p>

        <div class="hero-ctas">
          <a href="/app/bestellen" class="btn-primary btn-lg hero-cta">ÜBERSETZUNG + APOSTILLE BESTELLEN →</a>
        </div>

        <div class="hero-stats" aria-label="Kennzahlen">
          <div class="stats-divider"></div>
          <div class="stats-grid">
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Apostille ab €35,00
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Direkt vom Landgericht Hannover
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              Übersetzung + Apostille aus einer Hand
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              72 Std. Bearbeitung
            </div>
          </div>
        </div>
      </div>

      <div class="hero-gultig">
        <div class="gultig-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <div class="gultig-title">Gültig in 125 Ländern</div>
        <div class="gultig-sub">Haager Übereinkommen 1961</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · WAS IST EINE APOSTILLE
  ════════════════════════════════════════════════ -->
  <section class="basics" aria-labelledby="basics-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>GRUNDLAGEN</div>
      <h2 id="basics-h2" class="section-h2">Was ist eine Apostille?</h2>

      <div class="basics-grid">
        <div class="basics-card">
          <div class="basics-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 15 11 17 15 13"/></svg>
          </div>
          <h3>Internationale Echtheitsbescheinigung</h3>
          <p>
            Eine Apostille ist ein amtlicher Stempel, der die Echtheit der
            Unterschrift und des Siegels auf einem Dokument für das Ausland
            bestätigt.
          </p>
        </div>

        <div class="basics-card">
          <div class="basics-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Gültig in 125 Ländern</h3>
          <p>
            Alle Mitgliedsstaaten des Haager Übereinkommens von 1961
            akzeptieren die Apostille – darunter Ukraine, USA, Großbritannien
            und die meisten EU-Länder.
          </p>
        </div>

        <div class="basics-card">
          <div class="basics-icon basics-icon-warn">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3>Nicht für EU-Binnenverkehr</h3>
          <p>
            Innerhalb der EU brauchen Sie keine Apostille – beglaubigte
            Übersetzungen reichen aus. Die Apostille ist nur für
            Nicht-EU-Länder relevant.
          </p>
        </div>
      </div>

      <div class="info-block">
        <span class="info-icon" aria-hidden="true">ℹ️</span>
        <p>
          <strong>Wichtig:</strong> Eine Apostille ersetzt keine Übersetzung.
          Für fremdsprachige Dokumente brauchen Sie <strong>beides</strong>: eine{' '}
          <a href="/beglaubigte-uebersetzungen" class="text-link">beglaubigte Übersetzung</a>{' '}
          und ggf. eine <strong>Apostille</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · ORIGINAL VS. ÜBERSETZUNG
  ════════════════════════════════════════════════ -->
  <section class="originalvs" aria-labelledby="originalvs-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>HÄUFIGE VERWECHSLUNG</div>
      <h2 id="originalvs-h2" class="section-h2">Apostille auf das Original oder auf die Übersetzung?</h2>
      <p class="section-sub">
        Das sind zwei verschiedene Dokumente – und Sie brauchen möglicherweise beide.
      </p>

      <div class="originalvs-grid">
        <div class="ov-card ov-card-amber">
          <span class="ov-badge ov-badge-amber">NICHT BEI UNS ERHÄLTLICH</span>
          <div class="ov-icon ov-icon-amber">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><line x1="10" y1="6" x2="14" y2="6"/><line x1="10" y1="10" x2="14" y2="10"/></svg>
          </div>
          <h3>Apostille auf das Original</h3>

          <div class="ov-section">
            <p class="ov-section-label">WER STELLT SIE AUS?</p>
            <p class="ov-text">
              Wird ausgestellt von staatlichen Behörden des Landes, in dem
              das Dokument ausgestellt wurde.
            </p>
            <ul class="ov-list">
              <li>Für deutsche Urkunden: Landgericht, Regierungspräsidium, Standesamt</li>
              <li>Für ukrainische Urkunden: Ukrainisches Justizministerium</li>
            </ul>
          </div>

          <div class="ov-section">
            <p class="ov-section-label">WANN BENÖTIGT?</p>
            <p class="ov-text">
              Wenn Ihre Originaldokumente ins Ausland übermittelt werden
              sollen (z. B. Heirat in der Ukraine, Verwendung in einem
              Nicht-EU-Land).
            </p>
          </div>

          <p class="ov-footer ov-footer-amber">
            ⚠ Wir helfen Ihnen zu verstehen, ob Sie diese Apostille
            benötigen – aber wir stellen sie nicht selbst aus.
          </p>
        </div>

        <div class="ov-card ov-card-primary">
          <span class="ov-badge ov-badge-primary">WIR STELLEN SIE AUS</span>
          <div class="ov-icon ov-icon-primary">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Apostille auf unsere Übersetzung</h3>

          <div class="ov-section">
            <p class="ov-section-label">WER STELLT SIE AUS?</p>
            <p class="ov-text">
              Wird vom Landgericht Hannover auf die von Oleg Rosenblum
              erstellte beglaubigte Übersetzung gestellt.
            </p>
          </div>

          <div class="ov-section">
            <p class="ov-section-label">WANN BENÖTIGT?</p>
            <p class="ov-text">
              Wenn die deutsche Behörde oder ausländische Institution
              verlangt, dass auch die Übersetzung selbst apostilliert ist –
              nicht nur das Original.
            </p>
          </div>

          <div class="ov-price">
            <span class="ov-price-value">Preis: 35,00 €</span>
            <span class="ov-price-meta">· Bearbeitung: 72 Stunden · Deutschlandweit gültig</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · WIE SIEHT EINE APOSTILLE AUS
  ════════════════════════════════════════════════ -->
  <section class="schemes" aria-labelledby="schemes-h2">
    <div class="container">
      <h2 id="schemes-h2" class="section-h2">Wie sieht eine Apostille aus?</h2>

      <div class="schemes-grid">
        <div class="scheme-block">
          <p class="scheme-label"><img src="/media/flags/de.svg" alt="" width="22" height="16" class="scheme-flag" /> Deutsche Apostille (Landgericht)</p>
          <div class="scheme-doc">
            <div class="scheme-marked" data-marker="1">
              <div class="scheme-doc-title">A P O S T I L L E</div>
              <div class="scheme-doc-sub">(Convention de La Haye du 5 octobre 1961)</div>
              <p class="scheme-doc-row"><strong>Land: BUNDESREPUBLIK DEUTSCHLAND</strong></p>
              <span class="scheme-marker">1</span>
            </div>
            <div class="scheme-doc-line" style="width:88%"></div>
            <div class="scheme-doc-line" style="width:64%"></div>
            <div class="scheme-marked" data-marker="2">
              <p class="scheme-doc-row">durch das Saarland – Ministerium für Inneres und Sport</p>
              <span class="scheme-marker">2</span>
            </div>
            <div class="scheme-doc-line" style="width:70%"></div>
            <div class="scheme-doc-footer">
              <div class="scheme-marked" data-marker="3">
                <div class="scheme-stamp-circle"></div>
                <span class="scheme-marker">3</span>
              </div>
              <div class="scheme-marked" data-marker="4">
                <span class="scheme-doc-sign">Unterschrift</span>
                <span class="scheme-marker">4</span>
              </div>
            </div>
          </div>
          <ul class="scheme-legend">
            <li><span class="legend-num">1</span> Land — Ursprungsland des Dokuments</li>
            <li><span class="legend-num">2</span> Behörde — Ausstellende Institution</li>
            <li><span class="legend-num">3</span> Siegel — Offizielles Dienstsiegel</li>
            <li><span class="legend-num">4</span> Unterschrift — Amtliche Bestätigung</li>
          </ul>
        </div>

        <div class="scheme-block">
          <p class="scheme-label"><img src="/media/flags/ua.svg" alt="" width="22" height="16" class="scheme-flag" /> Ukrainische Apostille (Justizministerium)</p>
          <div class="scheme-doc">
            <div class="scheme-marked" data-marker="1">
              <div class="scheme-doc-title">APOSTILLE · АПОСТИЛЬ</div>
              <div class="scheme-doc-sub">(Convention de La Haye / Гаазька Конвенція від 5 жовтня 1961 року)</div>
              <p class="scheme-doc-row"><strong>Країна: Україна</strong></p>
              <span class="scheme-marker">1</span>
            </div>
            <div class="scheme-doc-line" style="width:80%"></div>
            <div class="scheme-marked" data-marker="2">
              <p class="scheme-doc-row">Підтверджено — головним спеціалістом Міністерства юстиції</p>
              <span class="scheme-marker">2</span>
            </div>
            <div class="scheme-doc-line" style="width:66%"></div>
            <div class="scheme-doc-footer">
              <div class="scheme-marked" data-marker="3">
                <div class="scheme-stamp-circle"></div>
                <span class="scheme-doc-sign">Печатка / Підпис</span>
                <span class="scheme-marker">3</span>
              </div>
            </div>
          </div>
          <ul class="scheme-legend">
            <li><span class="legend-num">1</span> Країна — Ursprungsland</li>
            <li><span class="legend-num">2</span> Підтверджено — Bestätigung der Behörde</li>
            <li><span class="legend-num">3</span> Печатка/Підпис — Siegel und Unterschrift</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 5 · BRAUCHE ICH EINE APOSTILLE (decision tree)
  ════════════════════════════════════════════════ -->
  <section class="decision-section" aria-labelledby="decision-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>ENTSCHEIDUNGSHILFE</div>
      <h2 id="decision-h2" class="section-h2">Brauche ich eine Apostille?</h2>
      <p class="section-sub">
        Beantworten Sie drei kurze Fragen – wir sagen Ihnen, was Sie brauchen.
      </p>

      <div class="decision-card" aria-live="polite">
        <div class="decision-progress" aria-hidden="true">
          <span class="decision-dot active" data-dot="1"></span>
          <span class="decision-dot" data-dot="2"></span>
          <span class="decision-dot" data-dot="3"></span>
        </div>

        <button type="button" class="decision-back" data-action="back" hidden>← Zurück</button>

        <div class="decision-screen" data-screen="step1">
          <p class="decision-question">Wohin soll Ihr Dokument?</p>
          <div class="decision-options">
            <button type="button" class="decision-option" data-next="result-deutsch">
              🏛️ An eine deutsche Behörde / Universität / Arbeitgeber
            </button>
            <button type="button" class="decision-option" data-next="step2-ausland">
              ✈️ Ins Ausland (Ukraine, USA, Großbritannien…)
            </button>
          </div>
        </div>

        <div class="decision-screen" data-screen="step2-ausland" hidden>
          <p class="decision-question">Ist das Zielland Mitglied des Haager Übereinkommens?</p>
          <p class="decision-subtext">Mitglieder: Ukraine, USA, UK, Australien, Kanada…</p>
          <div class="decision-options">
            <button type="button" class="decision-option" data-next="result-ja">✓ Ja, es ist Mitglied</button>
            <button type="button" class="decision-option" data-next="result-nein">✕ Nein / Nicht sicher</button>
          </div>
        </div>

        <div class="decision-screen decision-result decision-result-green" data-screen="result-deutsch" hidden>
          <div class="decision-result-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3>Wahrscheinlich keine Apostille nötig</h3>
          <p>
            Innerhalb Deutschlands und der EU wird keine Apostille
            benötigt. Sie brauchen eine{' '}
            <a href="/beglaubigte-uebersetzungen" class="text-link">beglaubigte Übersetzung</a> –
            die stellen wir aus.
          </p>
          <div class="decision-cta-row">
            <a href="/app/bestellen" class="btn-primary">Übersetzung bestellen →</a>
          </div>
          <a href="/app/bestellen" class="text-link decision-secondary-link">Trotzdem unsicher? Kostenlos fragen →</a>
        </div>

        <div class="decision-screen decision-result decision-result-blue" data-screen="result-ja" hidden>
          <div class="decision-result-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Sie benötigen eine Apostille auf das Original</h3>
          <p>
            Das Original-Dokument muss von der zuständigen Behörde im
            Ausstellungsland apostilliert werden. Zusätzlich brauchen Sie
            eine beglaubigte Übersetzung.
          </p>
          <div class="decision-cta-row">
            <a href="/app/bestellen" class="btn-primary">Übersetzung + Apostille bestellen →</a>
          </div>
        </div>

        <div class="decision-screen decision-result decision-result-amber" data-screen="result-nein" hidden>
          <div class="decision-result-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3>Statt Apostille: Legalisation</h3>
