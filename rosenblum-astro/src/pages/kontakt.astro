<script>
  // ── FAQ accordion ──────────────────────────────
  document.querySelectorAll('.faq-question').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = document.getElementById(btn.getAttribute('aria-controls') ?? '');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-question').forEach((other) => {
        other.setAttribute('aria-expanded', 'false');
        const otherBody = document.getElementById(other.getAttribute('aria-controls') ?? '');
        if (otherBody) (otherBody as HTMLElement).hidden = true;
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        if (body) (body as HTMLElement).hidden = false;
      }
    });
  });

  // ── Öffnungszeiten: heutigen Tag hervorheben ────
  const today = new Date().getDay();
  const rows = document.querySelectorAll<HTMLElement>('.opening-row');
  const mapping: Record<number, number> = { 1: 0, 2: 1, 3: 2, 4: 3, 5: 4 };
  if (mapping[today] !== undefined && rows[mapping[today]]) {
    rows[mapping[today]].classList.add('today');
    const srTag = document.createElement('span');
    srTag.className = 'sr-only';
    srTag.textContent = ' (heute)';
    rows[mapping[today]].querySelector('.opening-day')?.appendChild(srTag);
  }

  // ── Leaflet Karte: lazy init bei viewport-Eintritt ──
  const mapEl = document.getElementById('map');

  function initMap() {
    // @ts-ignore - L kommt vom global Leaflet-Script
    const L = (window as any).L;
    const map = L.map('map', { zoomControl: true }).setView([52.2715, 8.048], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap',
    }).addTo(map);
    L.marker([52.2715, 8.048])
      .addTo(map)
      .bindPopup('<b>Rosenblum Übersetzungsbüro</b><br>Alte Poststraße 25')
      .openPopup();
  }

  if (mapEl) {
    const mapObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          initMap();
          mapObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    mapObserver.observe(mapEl);
  }

  // ── Kontaktformular: Validierung & Submission ───
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement | null;
  const submitText = submitBtn?.querySelector('.submit-text');
  const submitError = document.getElementById('form-submit-error');
  const successEl = document.getElementById('form-success');

  function showFieldError(fieldId: string, errorId: string, show: boolean) {
    const field = document.getElementById(fieldId);
    const error = document.getElementById(errorId);
    if (!field || !error) return;
    if (show) {
      field.classList.add('invalid', 'shake');
      error.hidden = false;
      setTimeout(() => field.classList.remove('shake'), 400);
    } else {
      field.classList.remove('invalid');
      error.hidden = true;
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitError) submitError.hidden = true;

    const nameInput = document.getElementById('field-name') as HTMLInputElement;
    const emailInput = document.getElementById('field-email') as HTMLInputElement;
    const messageInput = document.getElementById('field-message') as HTMLTextAreaElement;

    const nameValid = nameInput.value.trim().length > 0;
    const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim());
    const messageValid = messageInput.value.trim().length > 0;

    showFieldError('field-name', 'error-name', !nameValid);
    showFieldError('field-email', 'error-email', !emailValid);
    showFieldError('field-message', 'error-message', !messageValid);

    if (!nameValid || !emailValid || !messageValid) {
      (!nameValid ? nameInput : !emailValid ? emailInput : messageInput).focus();
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.classList.add('loading');
    }
    if (submitText) submitText.textContent = 'Wird gesendet...';

    try {
      // TODO: настроить form submission endpoint (Formspree / Netlify Forms / Django API)
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameInput.value.trim(),
          email: emailInput.value.trim(),
          phone: (document.getElementById('field-phone') as HTMLInputElement)?.value.trim(),
          message: messageInput.value.trim(),
        }),
      });
      if (!res.ok) throw new Error('Submission failed');

      form.hidden = true;
      if (successEl) successEl.hidden = false;
    } catch {
      if (submitError) submitError.hidden = false;
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('loading');
      }
      if (submitText) submitText.textContent = 'Absenden';
    }
  });
</script>

