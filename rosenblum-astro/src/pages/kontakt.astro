---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';

const openingHours = [
  { day: 'Montag', hours: '9:00 – 12:00' },
  { day: 'Dienstag', hours: '15:00 – 18:00' },
  { day: 'Mittwoch', hours: '15:00 – 18:00' },
  { day: 'Donnerstag', hours: '9:00 – 12:00' },
  { day: 'Freitag', hours: '9:00 – 12:00' },
];

const findenIcons: Record<string, string> = {
  walk: '<circle cx="12" cy="4" r="1.5"/><path d="m10.5 21 1.5-6 1.5 6"/><path d="m7.5 8.5 4.5 1.5 4.5-1.5"/><path d="M12 10v5"/>',
  car: '<path d="M5 11 6.5 6.5A2 2 0 0 1 8.4 5h7.2a2 2 0 0 1 1.9 1.5L19 11"/><rect x="3" y="11" width="18" height="6" rx="2"/><circle cx="7.5" cy="17" r="1.5"/><circle cx="16.5" cy="17" r="1.5"/>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
};

const waysToFind = [
  {
    icon: 'walk',
    title: 'Zu Fuß / ÖPNV',
    text: 'Vom Hauptbahnhof Osnabrück ca. 10 Minuten zu Fuß. Bushaltestelle „Neumarkt" liegt direkt in der Nähe.',
  },
  {
    icon: 'car',
    title: 'Mit dem Auto',
    text: 'Parkmöglichkeiten in der Innenstadt (Parkhaus Berliner Platz, ca. 3 Gehminuten).',
  },
  {
    icon: 'calendar',
    title: 'Termin',
    text: 'Spontane Besuche während der Öffnungszeiten möglich. Für persönliche Beratung empfehlen wir eine kurze Voranmeldung per Telefon oder WhatsApp.',
  },
];

const reviews = [
  {
    text: '„Ich kann es zu 100 % empfehlen. So einfach und schnell war es noch nie – nur ein Foto schicken, alles läuft online. Nach zwei Tagen lag die beglaubigte Übersetzung schon im Briefkasten."',
    avatar: '/media/clients/Fekriia_Akhmetova.png',
    name: 'Fekriia Akhmetova',
  },
  {
    text: '„Ich habe eine Express-Übersetzung mit 24 Stunden Bearbeitungszeit bestellt. Obwohl die Bestellung erst abends einging, war alles am nächsten Tag fertig und versendet."',
    avatar: '/media/clients/Helena_Baida.png',
    name: 'Helena Baida',
  },
  {
    text: '„Ich habe Heirats- und Geburtsurkunden inklusive Apostillen übersetzen lassen. Alles war in drei Tagen erledigt – inklusive Zustellung nach Hause, absolut fehlerfrei."',
    avatar: '/media/clients/Vlad_Zhelenko.png',
    name: 'Vlad Zhelenko',
  },
];

const faqs = [
  {
    q: 'Muss ich einen Termin vereinbaren?',
    a: 'Nein – spontane Besuche während der Öffnungszeiten sind willkommen. Für eine ausführliche persönliche Beratung empfehlen wir jedoch eine kurze Voranmeldung per Telefon oder WhatsApp, damit wir uns Zeit für Sie nehmen können.',
  },
  {
    q: 'Kann ich meine Übersetzung auch online bestellen, ohne ins Büro zu kommen?',
    a: 'Ja, vollständig. Laden Sie Ihr Dokument auf unserer Bestellseite hoch – Sie erhalten den Kostenvoranschlag in 30 Minuten, wir übersetzen und schicken das Original per Post. Kein Bürobesuch nötig.',
  },
  {
    q: 'Sprechen Sie auch Ukrainisch oder Russisch?',
    a: 'Ja. Oleg Rosenblum spricht Deutsch, Ukrainisch, Russisch und Englisch. Sie können uns in jeder dieser Sprachen schreiben – per Formular, E-Mail oder WhatsApp.',
  },
  {
    q: 'Wie schnell bekomme ich einen Kostenvoranschlag?',
    a: 'In der Regel innerhalb von 30 Minuten während der Öffnungszeiten. Anfragen außerhalb der Öffnungszeiten beantworten wir am nächsten Werktag.',
  },
  {
    q: 'Kann ich das Originaldokument persönlich vorbeibringen?',
    a: 'Ja, gerne. Für die meisten Übersetzungen reicht jedoch ein Foto oder Scan – das Original müssen Sie nur dann einreichen, wenn die Behörde ausdrücklich verlangt, dass die Übersetzung am Original befestigt wird.',
  },
  {
    q: 'Übersetzen Sie auch für Kunden aus Melle, Bramsche oder anderen Orten im Landkreis?',
    a: 'Ja – wir betreuen Kunden aus dem gesamten Landkreis Osnabrück: Melle, Bramsche, Georgsmarienhütte, Bad Iburg, Belm, Bissendorf, Dissen, Hilter, Hasbergen, Wallenhorst und weitere. Da wir vollständig online arbeiten, spielt der Standort keine Rolle – Dokumente hochladen, Übersetzung per Post erhalten.',
  },
  {
    q: 'Liefern Sie auch außerhalb von Osnabrück?',
    a: 'Ja – wir arbeiten deutschlandweit. Die fertige beglaubigte Übersetzung schicken wir per Post an jede Adresse in Deutschland. Kunden in Berlin, Hamburg, München, Köln und überall sonst werden genauso betreut wie Kunden in Osnabrück.',
  },
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Rosenblum Übersetzungsbüro',
  description: 'Vereidigter Übersetzer für Ukrainisch und Russisch in Osnabrück. Beglaubigte Übersetzungen deutschlandweit.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Alte Poststraße 25',
    addressLocality: 'Osnabrück',
    postalCode: '49074',
    addressCountry: 'DE',
  },
  telephone: '+4917624137205',
  email: 'rosenblum.uebersetzungsbuero@gmail.com',
  url: 'https://rosenblum-uebersetzungen.de',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Thursday', 'Friday'], opens: '09:00', closes: '12:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Tuesday', 'Wednesday'], opens: '15:00', closes: '18:00' },
  ],
  geo: { '@type': 'GeoCoordinates', latitude: 52.2715, longitude: 8.048 },
  priceRange: 'ab €30,30',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '50' },
  areaServed: [
    { '@type': 'City', name: 'Osnabrück' },
    { '@type': 'City', name: 'Melle' },
    { '@type': 'City', name: 'Georgsmarienhütte' },
    { '@type': 'City', name: 'Bramsche' },
    { '@type': 'City', name: 'Bad Iburg' },
    { '@type': 'City', name: 'Belm' },
    { '@type': 'City', name: 'Bissendorf' },
    { '@type': 'City', name: 'Dissen am Teutoburger Wald' },
    { '@type': 'City', name: 'Hilter am Teutoburger Wald' },
    { '@type': 'City', name: 'Hasbergen' },
    { '@type': 'City', name: 'Wallenhorst' },
    { '@type': 'AdministrativeArea', name: 'Landkreis Osnabrück' },
    { '@type': 'Country', name: 'Germany' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Kontakt', item: 'https://rosenblum-uebersetzungen.de/kontakt/' },
  ],
};
---

<BaseLayout
  title="Kontakt – Übersetzer in Osnabrück | Rosenblum Übersetzungsbüro"
  description="Rosenblum Übersetzungsbüro in Osnabrück. Vereidigter Übersetzer für Ukrainisch & Russisch. Kostenvoranschlag in 30 Min. Schreiben Sie uns auf Deutsch, Ukrainisch oder Russisch."
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/kontakt/"
  schema={[localBusinessSchema, faqSchema, breadcrumbSchema]}
>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 1 · HERO + KONTAKTINFO + KARTE
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container">
      <div class="hero-text">
        <h1 class="hero-h1">
          Übersetzer in Osnabrück –<br />
          <span class="hero-accent">Vereidigt</span> für Ukrainisch &amp; Russisch
        </h1>
        <p class="hero-sub">
          Wir freuen uns auf Ihre Anfrage und stehen Ihnen gerne zur Verfügung.
        </p>

        <div class="rating-badge">★ 4,8 · 50 Google-Bewertungen</div>

        <div class="contact-buttons">
          <a
            href="https://wa.me/4917624137205"
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-btn"
            aria-label="WhatsApp schreiben, öffnet WhatsApp"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.87 11.92L4 20l4.2-1.1a7.9 7.9 0 0 0 3.84 1h.01a7.95 7.95 0 0 0 5.55-13.58zM12.05 18.4h-.01a6.55 6.55 0 0 1-3.36-.92l-.24-.14-2.5.65.67-2.43-.16-.25a6.6 6.6 0 0 1 10.27-8.2 6.55 6.55 0 0 1 1.93 4.67 6.6 6.6 0 0 1-6.6 6.62zm3.6-4.93c-.2-.1-1.17-.58-1.35-.64-.18-.07-.31-.1-.45.1-.13.2-.51.64-.63.77-.11.13-.23.14-.43.05-1.18-.59-1.95-1.05-2.73-2.38-.21-.35.21-.33.6-1.1.07-.13.03-.25-.02-.35-.06-.1-.5-1.2-.68-1.65-.18-.43-.37-.37-.5-.38h-.43c-.15 0-.38.06-.59.3-.2.25-.78.76-.78 1.85s.8 2.15.91 2.3c.11.13 1.55 2.37 3.78 3.32 1.87.8 2.26.65 2.66.6.4-.04 1.3-.53 1.48-1.04.18-.51.18-.95.13-1.04-.05-.1-.18-.15-.38-.25z"/></svg>
            WhatsApp schreiben →
          </a>
          <a
            href="https://t.me/oleg_rosenblum"
            target="_blank"
            rel="noopener noreferrer"
            class="telegram-btn"
            aria-label="Telegram schreiben, öffnet Telegram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3L19.34 4.18c.73-.33 1.43.18 1.15 1.3l-3.21 15.1c-.22 1.02-.78 1.21-1.5.92l-4.18-3.45L9.78 18.65z"/></svg>
            Telegram schreiben →
          </a>
        </div>
        <p class="whatsapp-sub">Antwort meist innerhalb von 30 Minuten</p>
      </div>

      <div class="hero-content-grid">
        <div class="contact-cards-col">
          <div class="info-card">
            <div class="info-card-header">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h2 class="info-card-title">Kontaktinformationen</h2>
            </div>
            <div class="info-row">
              <span class="info-label">ZUSTÄNDIGE PERSON</span>
              <div class="info-row-body">
                <span class="info-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                <span class="info-text">Oleg Rosenblum, beeidigter Dolmetscher und ermächtigter Übersetzer vom Landgericht Hannover</span>
              </div>
            </div>
            <div class="info-row">
              <span class="info-label">ADRESSE</span>
              <div class="info-row-body">
                <span class="info-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
                <span class="info-text">Alte Poststraße 25, 49074 Osnabrück</span>
              </div>
            </div>
            <div class="info-row">
              <span class="info-label">TELEFON</span>
              <div class="info-row-body">
                <span class="info-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                <a href="tel:+4917624137205" class="info-link">0176 24137205</a>
              </div>
            </div>
            <div class="info-row">
              <span class="info-label">E-MAIL</span>
              <div class="info-row-body">
                <span class="info-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><polyline points="22 6 12 13 2 6"/></svg></span>
                <a href="mailto:rosenblum.uebersetzungsbuero@gmail.com" class="info-link info-link-sm">rosenblum.uebersetzungsbuero@gmail.com</a>
              </div>
            </div>
            <div class="info-row">
              <span class="info-label">SPRACHEN</span>
              <div class="info-row-body">
                <span class="info-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
                <span class="info-text">Deutsch · Ukrainisch · Русский · English</span>
              </div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-card-header">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h2 class="info-card-title">Öffnungszeiten</h2>
            </div>
            <div class="opening-rows">
              {openingHours.map((o) => (
                <div class="opening-row">
                  <span class="opening-day">{o.day}</span>
                  <span class="opening-hours">{o.hours}</span>
                </div>
              ))}
            </div>
            <div class="opening-info">
              Termine nach Vereinbarung auch außerhalb der Öffnungszeiten möglich.
            </div>
          </div>
        </div>

        <div class="visual-col">
          <div class="visual-card">
            <div class="office-photo">
              <img src="/media/buero.png" alt="Büro von Rosenblum Übersetzungsbüro in der Alte Poststraße 25, Osnabrück" />
            </div>
            <div class="map-wrap">
              <div id="map" class="map" role="application" aria-label="Standort Rosenblum Übersetzungsbüro in Osnabrück"></div>
              <a
                href="https://maps.google.com/?q=Alte+Poststraße+25,+49074+Osnabrück"
                target="_blank"
                rel="noopener noreferrer"
                class="map-open-link"
              >
                In Maps öffnen →
              </a>
            </div>
          </div>
          <p class="visual-caption">Unser Büro in der Alte Poststraße 25, Osnabrück</p>

          <div class="landkreis-info">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <p>
              Wir übersetzen für Kunden in Osnabrück und der gesamten Region –{' '}
              <strong>Melle, Bramsche, Georgsmarienhütte, Bad Iburg, Belm, Bissendorf, Dissen, Hilter, Hasbergen</strong> und Wallenhorst.
              Dokumente online einreichen, fertige Übersetzung kommt per Post.{' '}
              <a href="/beglaubigte-uebersetzungen/">Deutschlandweit →</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · MEHRSPRACHIG WILLKOMMEN
  ════════════════════════════════════════════════ -->
  <section class="mehrsprachig" aria-label="Mehrsprachig willkommen">
    <div class="container mehrsprachig-inner">
      <h2 class="mehrsprachig-h2">Sie können uns in Ihrer Sprache schreiben</h2>
      <div class="lang-blocks">
        <div class="lang-block">
          <img src="/media/flags/de.svg" alt="" class="lang-flag" />
          <span class="lang-name">Deutsch</span>
          <span class="lang-phrase">Schreiben Sie uns auf Deutsch</span>
        </div>
        <div class="lang-block">
          <img src="/media/flags/ua.svg" alt="" class="lang-flag" />
          <span class="lang-name">Українська</span>
          <span class="lang-phrase">Пишіть нам українською</span>
        </div>
        <div class="lang-block">
          <img src="/media/flags/ru.svg" alt="" class="lang-flag" />
          <span class="lang-name">Русский</span>
          <span class="lang-phrase">Пишите нам по-русски</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · WIE FINDEN SIE UNS?
  ════════════════════════════════════════════════ -->
  <section class="wie-finden" aria-labelledby="wie-finden-h2">
    <div class="container">
      <h2 id="wie-finden-h2" class="section-h2 centered">Wie finden Sie uns?</h2>
      <div class="finden-grid">
        {waysToFind.map((w) => (
          <div class="finden-card">
            <div class="finden-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={findenIcons[w.icon]} />
            </div>
            <h3 class="finden-title">{w.title}</h3>
            <p class="finden-text">{w.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · KONTAKTFORMULAR
  ════════════════════════════════════════════════ -->
  <section class="formular" aria-labelledby="formular-h2">
    <div class="container">
      <div class="formular-card">
        <div class="formular-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <div>
            <h2 id="formular-h2" class="formular-h2">Schreiben Sie uns</h2>
            <p class="formular-sub">Füllen Sie das Formular aus und wir melden uns schnellstmöglich bei Ihnen.</p>
          </div>
        </div>

        <a href="/app/bestellen" class="bestell-hint">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span class="bestell-hint-text">Möchten Sie direkt ein Dokument zur Übersetzung einsenden?</span>
          <span class="bestell-hint-link">Zur Bestellseite →</span>
        </a>

        <form id="contact-form" novalidate>
          <div class="form-row form-row-2col">
            <div class="form-field">
              <label for="field-name" class="form-label">Vorname und Nachname</label>
              <div class="form-input-wrap">
                <svg class="form-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <input type="text" id="field-name" name="name" class="form-input" placeholder="Ihr Name" required aria-required="true" aria-describedby="error-name" />
              </div>
              <p class="form-error" id="error-name" role="alert" hidden>Bitte geben Sie Ihren Namen ein.</p>
            </div>
            <div class="form-field">
              <label for="field-email" class="form-label">Email</label>
              <div class="form-input-wrap">
                <svg class="form-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
                <input type="email" id="field-email" name="email" class="form-input" placeholder="Ihre E-Mail-Adresse" required aria-required="true" aria-describedby="error-email" />
              </div>
              <p class="form-error" id="error-email" role="alert" hidden>Bitte geben Sie eine gültige E-Mail-Adresse ein.</p>
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="field-phone" class="form-label">Telefonnummer</label>
              <div class="form-input-wrap">
