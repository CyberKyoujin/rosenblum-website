---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';
import languages from '../data/languages.json';

const langCount = languages.length;

const translationSchema = {
  '@context': 'https://schema.org',
  '@type': 'TranslationService',
  name: 'Rosenblum Übersetzungsbüro',
  url: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzungen/',
  provider: {
    '@type': 'Person',
    name: 'Oleg Rosenblum',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Vereidigter Übersetzer',
      recognizedBy: {
        '@type': 'Organization',
        name: 'Landgericht Hannover',
      },
    },
  },
  serviceType: 'Beglaubigte Übersetzung',
  inLanguage: languages.map((l) => l.iso),
  outLanguage: 'de',
  areaServed: [{ '@type': 'Country', name: 'Germany' }],
  priceRange: 'ab €30,30',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '26',
  },
};

const faqs = [
  {
    q: 'Was ist eine beglaubigte Übersetzung?',
    a: 'Eine beglaubigte Übersetzung ist eine von einem vereidigten Übersetzer angefertigte Übersetzung, die mit Siegel und handschriftlicher Unterschrift bestätigt wird. Sie wird von allen deutschen Behörden, Gerichten und Universitäten anerkannt.',
  },
  {
    q: 'Wann brauche ich eine beglaubigte Übersetzung?',
    a: 'Immer dann, wenn eine deutsche Behörde, ein Gericht, eine Universität oder ein Arbeitgeber ein fremdsprachiges Dokument verlangt. Typische Anlässe: Aufenthaltstitel, Einbürgerung, Studium, Anerkennung ausländischer Berufsabschlüsse.',
  },
  {
    q: 'Was kostet eine beglaubigte Übersetzung?',
    a: 'Standarddokumente wie Geburtsurkunde oder Heiratsurkunde kosten ab €30,30. Umfangreichere Dokumente wie Diplome werden nach Zeilenpreis berechnet. Den genauen Preis erhalten Sie in unserem kostenlosen Kostenvoranschlag innerhalb von 30 Minuten.',
  },
  {
    q: 'Wie lange dauert eine beglaubigte Übersetzung?',
    a: 'Standard: 72 Stunden. Express: 24 Stunden (Aufpreis). Bei dringendem Bedarf sprechen Sie uns an – wir finden eine Lösung.',
  },
  {
    q: 'Kann das Jobcenter die Kosten übernehmen?',
    a: 'Ja. Nach §44 SGB III können Jobcenter und Agentur für Arbeit die Kosten für beglaubigte Übersetzungen übernehmen. Wir stellen die Rechnung direkt aus – Sie zahlen nichts. Fragen Sie uns nach einem entsprechenden Kostenvoranschlag.',
  },
  {
    q: 'Ist eine beglaubigte Übersetzung dasselbe wie eine notarielle Beglaubigung?',
    a: 'Nein – das sind zwei völlig verschiedene Dinge. Ein Notar bestätigt nur, dass eine Kopie mit dem Original übereinstimmt, er übersetzt nichts. Für fremdsprachige Dokumente bei Behörden brauchen Sie zwingend eine beglaubigte Übersetzung von einem vereidigten Übersetzer.',
  },
  {
    q: 'Welche Sprachen übersetzen Sie?',
    a: `Wir übersetzen aus ${langCount} Sprachen: ${languages.slice(0, -1).map((l) => l.name).join(', ')} und ${languages[languages.length - 1].name} – ins Deutsche. Auf Anfrage auch in die Gegenrichtung.`,
  },
  {
    q: 'Muss ich das Originaldokument einsenden?',
    a: 'Nein. Ein Scan oder ein Handyfoto reicht für die Übersetzung aus. Das Original benötigen wir nur wenn die Behörde ausdrücklich verlangt, dass die Übersetzung am Original befestigt wird. Das teilen wir Ihnen im Kostenvoranschlag mit.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Beglaubigte Übersetzungen',
      item: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzungen/',
    },
  ],
};

const anatomyPoints = [
  {
    n: 1,
    title: 'Kopfzeile des Übersetzers',
    text: 'Name, Titel, Kontaktdaten und Landgericht-Ermächtigung des vereidigten Übersetzers.',
  },
  {
    n: 2,
    title: 'Übersetzungsinhalt',
    text: 'Die vollständige inhaltliche Übersetzung des Originaldokuments – Wort für Wort, ohne Auslassungen.',
  },
  {
    n: 3,
    title: 'Beglaubigungsvermerk',
    text: 'Die offizielle Erklärung des Übersetzers, dass die Übersetzung korrekt und vollständig ist. Rechtlich bindend.',
  },
  {
    n: 4,
    title: 'Rundstempel (Siegel)',
    text: 'Das offizielle Siegel des vereidigten Übersetzers mit Landgericht-Ermächtigung. Unverwechselbar und rechtsgültig.',
  },
  {
    n: 5,
    title: 'Handschriftliche Unterschrift',
    text: 'Die persönliche Unterschrift von Oleg Rosenblum – rechtlich bindend und gerichtlich überprüfbar.',
  },
  {
    n: 6,
    title: 'Datum und Ort',
    text: 'Datum und Ort der Beglaubigung – für die Behörden zur Verifikation der Aktualität.',
  },
];

const comparisonRows = [
  { label: 'Von wem?', simple: 'Jeder Übersetzer oder Muttersprachler', certified: 'Nur vereidigter Übersetzer (Landgericht)' },
  { label: 'Offizielles Siegel', simple: 'Nein', certified: 'Ja – Rundstempel mit Ermächtigung' },
  { label: 'Unterschrift', simple: 'Keine offizielle', certified: 'Handschriftlich, rechtlich bindend' },
  { label: 'Bei Behörden', simple: 'Nein', certified: 'Ja – deutschlandweit' },
  { label: 'Bei Gerichten', simple: 'Nein', certified: 'Ja' },
  { label: 'Für Jobcenter / AfA', simple: 'Nicht akzeptiert', certified: 'Kostenübernahme §44 möglich' },
  { label: 'Online-Tools', simple: 'Nicht offiziell', certified: 'Ersetzt keine Beglaubigung' },
];

const matrixTabs = [
  {
    id: 'auslaenderbehoerde',
    icon: '🏛️',
    name: 'Ausländerbehörde',
    docs: [
      { name: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { name: 'Heiratsurkunde', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
      { name: 'Reisepass (Datenseite)', href: '/beglaubigte-uebersetzung/reisepass' },
      { name: 'Meldebescheinigung', href: '/beglaubigte-uebersetzung/meldebescheinigung' },
      { name: 'ggf. Scheidungsurteil', href: '/beglaubigte-uebersetzung/gerichtsentscheidung' },
    ],
  },
  {
    id: 'standesamt',
    icon: '💍',
    name: 'Standesamt',
    docs: [
      { name: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { name: 'Heiratsurkunde', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
      { name: 'Ledigkeitsbescheinigung', href: '/beglaubigte-uebersetzung/ledigkeitsbescheinigung' },
      { name: 'Scheidungsurteil', href: '/beglaubigte-uebersetzung/gerichtsentscheidung' },
      { name: 'Sterbeurkunde', href: '/beglaubigte-uebersetzung/sterbeurkunde' },
    ],
  },
  {
    id: 'jobcenter',
    icon: '💼',
    name: 'Jobcenter / AfA',
    docs: [
      { name: 'Diplom / Zeugnis', href: '/beglaubigte-uebersetzung/diplom' },
      { name: 'Arbeitszeugnisse', href: '/beglaubigte-uebersetzung/arbeitszeugnis' },
      { name: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { name: 'Führerschein', href: '/beglaubigte-uebersetzung/fuehrerschein' },
    ],
    info: 'Kostenübernahme durch Jobcenter nach §44 SGB III möglich',
  },
  {
    id: 'universitaet',
    icon: '🎓',
    name: 'Universität / Uni-Assist',
    docs: [
      { name: 'Diplom / Bachelor', href: '/beglaubigte-uebersetzung/diplom' },
      { name: 'Transcript of Records', href: '/beglaubigte-uebersetzung/diplom' },
      { name: 'Geburtsurkunde', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
      { name: 'Sprachzertifikat', href: '/beglaubigte-uebersetzung/zertifikat' },
    ],
  },
  {
    id: 'arbeitgeber',
    icon: '🏢',
    name: 'Arbeitgeber / Anerkennung',
    docs: [
      { name: 'Diplom / Zeugnis', href: '/beglaubigte-uebersetzung/diplom' },
      { name: 'Führungszeugnis', href: '/beglaubigte-uebersetzung/fuehrungszeugnis' },
      { name: 'Arbeitszeugnisse', href: '/beglaubigte-uebersetzung/arbeitszeugnis' },
      { name: 'Berufsqualifikation', href: '/beglaubigte-uebersetzung/diplom' },
    ],
  },
  {
    id: 'gerichte',
    icon: '⚖️',
    name: 'Gerichte',
    docs: [
      { name: 'Gerichtsentscheidung', href: '/beglaubigte-uebersetzung/gerichtsentscheidung' },
      { name: 'Vollmacht', href: '/beglaubigte-uebersetzung/vollmacht' },
      { name: 'Vertrag', href: '/beglaubigte-uebersetzung/vertrag' },
      { name: 'Urteil', href: '/beglaubigte-uebersetzung/gerichtsentscheidung' },
    ],
  },
];
---

<BaseLayout
  title="Beglaubigte Übersetzung – vereidigt, schnell, rechtsgültig | Rosenblum"
  description={`Beglaubigte Übersetzungen vom vereidigten Übersetzer am Landgericht Hannover. Alle Behörden, ${langCount} Sprachen, ab €30,30. Kostenvoranschlag in 30 Min.`}
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzungen/"
  schema={[translationSchema, faqSchema, breadcrumbSchema]}
>
  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 1 · HERO
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-grid">
      <div class="hero-top">
        <div class="hero-badge" aria-label="Zertifizierung">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Beglaubigte Übersetzung · Vereidigt · Rechtsgültig
        </div>

        <h1 class="hero-h1">
          Beglaubigte Übersetzung —<br />
          <span class="hero-accent">schnell</span>, günstig, rechtsgültig
        </h1>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-float hero-float-top">
          <div class="float-check">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="float-title">Vom Gericht beglaubigt</div>
            <div class="float-sub">Amtlich anerkannt</div>
          </div>
        </div>

        <div class="hero-doc">
          <div class="doc-header">
            <div class="doc-circle"></div>
            <div class="doc-lines-header">
              <div class="doc-line" style="width:70%"></div>
              <div class="doc-line" style="width:45%"></div>
            </div>
          </div>
          <div class="doc-body">
            <div class="doc-line" style="width:100%"></div>
            <div class="doc-line" style="width:88%"></div>
            <div class="doc-line" style="width:94%"></div>
            <div class="doc-line" style="width:72%"></div>
          </div>
          <div class="doc-footer">
            <span class="doc-label">— Vereidigter Übersetzer</span>
            <span class="doc-signature">O. Rosenblum</span>
          </div>
          <div class="doc-stamp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span class="stamp-line">BEGLAUBIGT</span>
            <span class="stamp-line">LG HANNOVER</span>
          </div>
        </div>

        <div class="hero-float hero-float-bottom">
          <div class="float-icon-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 6L2 7"/></svg>
          </div>
          <div>
            <div class="float-title">Express 24 Std.</div>
            <div class="float-sub">Deutschlandweit per Post</div>
          </div>
        </div>
      </div>

      <div class="hero-bottom">
        <p class="hero-sub">
          Vom vereidigten Übersetzer am Landgericht Hannover. Deutschlandweit
          anerkannt – bei allen Behörden, Gerichten und Universitäten.
        </p>

        <div class="hero-ctas">
          <a href="/app/bestellen" class="btn-primary btn-lg hero-cta">KOSTENVORANSCHLAG IN 30 MIN. →</a>
          <a href="/preise" class="btn-ghost">Zur Preisliste →</a>
        </div>

        <div class="hero-stats" aria-label="Kennzahlen">
          <div class="stats-divider"></div>
          <div class="stats-grid">
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Vereidigt LG Hannover
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Ab €30,30 Festpreis
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Express 24 Std.
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              {langCount} Sprachen
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-star)" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              4,8/5 Google (50 Bewertungen)
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · OFFIZIELL ERMÄCHTIGT
  ════════════════════════════════════════════════ -->
  <section class="register" aria-labelledby="register-h2">
    <div class="container register-grid">
      <div class="register-visual">
        <div class="register-card">
          <img src="/media/oleg.jpg" alt="Oleg Rosenblum" class="register-photo" width="88" height="88" />
          <h3 class="register-name">Oleg Rosenblum</h3>
          <p class="register-label">JUSTIZ-DOLMETSCHER-REGISTER</p>
          <div class="register-divider"></div>
          <a
            href="https://www.justizportal-niedersachsen.de/"
            target="_blank"
            rel="noopener noreferrer"
            class="register-link"
          >
            Eintrag im amtlichen Register prüfen →
          </a>
        </div>
      </div>

      <div class="register-content">
        <p class="register-eyebrow">E-E-A-T</p>
        <h2 id="register-h2" class="register-h2">Offiziell ermächtigt</h2>
        <p class="register-text">
          Oleg Rosenblum ist im offiziellen Verzeichnis der allgemein beeidigten
          Dolmetscher und ermächtigten Übersetzer eingetragen – gerichtlich überprüfbar.
        </p>
        <ul class="register-checklist">
          <li class="register-check-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Vereidigt &amp; ermächtigt durch das <strong>Landgericht Hannover</strong></span>
          </li>
          <li class="register-check-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Jede Übersetzung trägt ein <strong>offizielles Siegel</strong> und eine <strong>handschriftliche Unterschrift</strong></span>
          </li>
          <li class="register-check-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Bundesweit gültig – von allen deutschen Behörden anerkannt</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · ANATOMIE EINER BEGLAUBIGTEN ÜBERSETZUNG
  ════════════════════════════════════════════════ -->
  <section class="anatomy" aria-labelledby="anatomy-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>SIGNATUR-ELEMENT</div>
      <h2 id="anatomy-h2" class="section-h2">Anatomie einer beglaubigten Übersetzung</h2>
      <p class="section-sub">
        So sieht ein offizielles Dokument aus – fahren Sie über die Markierungen.{' '}
        <span class="mobile-only-hint">Tippen Sie auf die nummerierten Punkte.</span>
      </p>

      <div class="anatomy-grid">
        <!-- Accordion (order 2 on mobile via CSS) -->
        <div class="anatomy-accordion" role="list">
          {anatomyPoints.map((p, i) => (
            <div class="anatomy-item" role="listitem">
              <button
                class="anatomy-header"
                data-marker={p.n}
                aria-expanded={i === 0 ? 'true' : 'false'}
                aria-controls={`anatomy-body-${p.n}`}
                id={`anatomy-btn-${p.n}`}
              >
                <span class="anatomy-num">{p.n}</span>
                <span class="anatomy-title">{p.title}</span>
                <span class="anatomy-chevron" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </button>
              <div
                class="anatomy-body"
                id={`anatomy-body-${p.n}`}
                role="region"
                aria-labelledby={`anatomy-btn-${p.n}`}
                hidden={i !== 0}
              >
                <p>{p.text}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Document scheme -->
        <div class="anatomy-doc-wrap">
          <div class="anatomy-doc" aria-label="Beispiel-Dokument mit nummerierten Elementen">
            <div class="anatomy-marked" data-marker-target="1">
              <div class="adoc-header">
                <div class="adoc-circle">R</div>
                <div class="adoc-header-text">
                  <strong>Oleg Rosenblum</strong>
                  <span>Vom Landgericht Hannover ermächtigter Übersetzer</span>
                  <span>Osnabrück · rosenblum.uebersetzungsbuero@gmail.com</span>
                </div>
              </div>
              <span class="anatomy-marker" aria-hidden="true">1</span>
            </div>

            <h4 class="adoc-title">Beglaubigte Übersetzung aus dem Ukrainischen</h4>

            <div class="anatomy-marked anatomy-marked-center" data-marker-target="2">
              <div class="adoc-body">
                <div class="adoc-line" style="width:100%"></div>
                <div class="adoc-line" style="width:92%"></div>
                <div class="adoc-line" style="width:96%"></div>
                <div class="adoc-line" style="width:64%"></div>
              </div>
              <span class="anatomy-marker" aria-hidden="true">2</span>
            </div>

            <div class="anatomy-marked" data-marker-target="3">
              <p class="adoc-vermerk">
                „Die Richtigkeit und Vollständigkeit der vorstehenden Übersetzung
                aus dem Ukrainischen wird hiermit bestätigt."
              </p>
              <span class="anatomy-marker anatomy-marker-below" aria-hidden="true">3</span>
            </div>

            <div class="adoc-footer">
              <div class="anatomy-marked" data-marker-target="4">
                <div class="adoc-stamp-round">
                  VEREIDIGTER ÜBERSETZER · O. ROSENBLUM · LG HANNOVER
                </div>
                <span class="anatomy-marker" aria-hidden="true">4</span>
              </div>
              <div class="adoc-sign-block">
                <div class="anatomy-marked" data-marker-target="5">
                  <span class="adoc-signature">Oleg Rosenblum</span>
                  <span class="anatomy-marker" aria-hidden="true">5</span>
                </div>
                <div class="anatomy-marked" data-marker-target="6">
                  <span class="adoc-date">Osnabrück, 11.06.2026</span>
                  <span class="anatomy-marker" aria-hidden="true">6</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · BEGLAUBIGTE ≠ NOTARIELLE BEGLAUBIGUNG
  ════════════════════════════════════════════════ -->
  <section class="distinction" aria-labelledby="distinction-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>HÄUFIGE VERWECHSLUNG</div>
      <h2 id="distinction-h2" class="section-h2">
        Beglaubigte Übersetzung <span class="hero-accent">≠</span> notarielle Beglaubigung
      </h2>
      <p class="section-sub">
        Zwei völlig verschiedene Dinge – und nur eine davon hilft Ihnen bei der Behörde.
      </p>

      <div class="distinction-grid">
        <div class="distinction-card distinction-need">
