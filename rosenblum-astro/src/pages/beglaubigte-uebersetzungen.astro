<script>
  // ── Anatomy accordion + document marker linking ──
  const anatomyHeaders = document.querySelectorAll('.anatomy-header');
  const markers = document.querySelectorAll('.anatomy-marker');
  const markedBlocks = document.querySelectorAll('.anatomy-marked');

  function activateAnatomy(n: string) {
    anatomyHeaders.forEach((btn) => {
      const isMatch = btn.getAttribute('data-marker') === n;
      btn.setAttribute('aria-expanded', String(isMatch));
      const body = document.getElementById(btn.getAttribute('aria-controls') ?? '');
      if (body) body.hidden = !isMatch;
    });
    markedBlocks.forEach((block) => {
      block.classList.toggle('active', block.getAttribute('data-marker-target') === n);
    });
  }

  anatomyHeaders.forEach((btn) => {
    btn.addEventListener('click', () => {
      const n = btn.getAttribute('data-marker') ?? '';
      const alreadyOpen = btn.getAttribute('aria-expanded') === 'true';
      activateAnatomy(alreadyOpen ? '' : n);
    });
  });

  markers.forEach((marker) => {
    const parent = marker.closest('.anatomy-marked');
    const n = parent?.getAttribute('data-marker-target') ?? '';
    marker.addEventListener('click', () => activateAnatomy(n));
    parent?.addEventListener('mouseenter', () => activateAnatomy(n));
  });

  // ── Distinction / FAQ generic accordion ──
  function setupAccordion(selector: string) {
    document.querySelectorAll(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const body = document.getElementById(btn.getAttribute('aria-controls') ?? '');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll(selector).forEach((other) => {
          other.setAttribute('aria-expanded', 'false');
          const otherBody = document.getElementById(other.getAttribute('aria-controls') ?? '');
          if (otherBody) otherBody.hidden = true;
        });
        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          if (body) body.hidden = false;
        }
      });
    });
  }
  setupAccordion('.faq-question');

  // ── Dokumenten-Matrix tabs ──
  const tabs = document.querySelectorAll<HTMLButtonElement>('.matrix-tab');
  const panels = document.querySelectorAll<HTMLElement>('.matrix-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        t.setAttribute('aria-selected', String(t === tab));
        t.tabIndex = t === tab ? 0 : -1;
      });
      panels.forEach((p) => {
        p.hidden = p.getAttribute('data-panel') !== target;
      });
    });

    tab.addEventListener('keydown', (e: KeyboardEvent) => {
      const list = Array.from(tabs);
      const idx = list.indexOf(tab);
      if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        e.preventDefault();
        const nextIdx = e.key === 'ArrowRight'
          ? (idx + 1) % list.length
          : (idx - 1 + list.length) % list.length;
        list[nextIdx].focus();
        list[nextIdx].click();
      }
    });
  });
</script>

