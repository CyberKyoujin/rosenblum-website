<script>
  // ── Language row tooltips ──────────────────────
  const langCodes = document.querySelectorAll('.lang-code');

  langCodes.forEach((el) => {
    const showTooltip = (e: Event) => {
      e.stopPropagation();
      // Hide all others
      langCodes.forEach((other) => {
        if (other !== el) other.querySelector('.lang-tooltip')?.classList.remove('visible');
      });
      el.querySelector('.lang-tooltip')?.classList.toggle('visible');
    };

    el.addEventListener('click', showTooltip);
    el.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') {
        ke.preventDefault();
        showTooltip(e);
      }
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.lang-tooltip.visible').forEach((t) => t.classList.remove('visible'));
  });

  // ── Behörden accordion ─────────────────────────
  const accordionBtns = document.querySelectorAll('.behoerde-header');

  accordionBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = document.getElementById(btn.getAttribute('aria-controls') ?? '');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      const toggle = btn.querySelector('.behoerde-toggle');

      // Close all
      accordionBtns.forEach((other) => {
        other.setAttribute('aria-expanded', 'false');
        const otherBody = document.getElementById(other.getAttribute('aria-controls') ?? '');
        if (otherBody) otherBody.hidden = true;
        const otherToggle = other.querySelector('.behoerde-toggle');
        if (otherToggle) otherToggle.textContent = '+';
      });

      // Toggle current
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        if (body) body.hidden = false;
        if (toggle) toggle.textContent = '×';
      }
    });
  });

  // ── Scroll-driven step animations ─────────────
  const stepCards = document.querySelectorAll('.step-card');
  if ('IntersectionObserver' in window) {
    const stepObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.opacity = '1';
            (entry.target as HTMLElement).style.transform = 'translateY(0)';
            stepObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    stepCards.forEach((card) => {
      (card as HTMLElement).style.opacity = '0';
      (card as HTMLElement).style.transform = 'translateY(20px)';
      (card as HTMLElement).style.transition = `opacity 0.4s ease ${(card as HTMLElement).style.animationDelay}, transform 0.4s ease ${(card as HTMLElement).style.animationDelay}`;
      stepObserver.observe(card);
    });
  }
</script>

