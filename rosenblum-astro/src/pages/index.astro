---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';
import languages from '../data/languages.json';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Rosenblum Übersetzungsbüro',
  url: 'https://rosenblum-uebersetzungen.de',
  description:
    `Vereidigter Übersetzer am Landgericht Hannover. Beglaubigte Übersetzungen in ${languages.length} Sprachen.`,
};

const translationSchema = {
  '@context': 'https://schema.org',
  '@type': 'TranslationService',
  name: 'Rosenblum Übersetzungsbüro',
  url: 'https://rosenblum-uebersetzungen.de',
  provider: {
    '@type': 'Person',
    name: 'Oleg Rosenblum',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Vereidigter Übersetzer',
      recognizedBy: {
        '@type': 'Organization',
        name: 'Landgericht Hannover',
      },
    },
  },
  serviceType: 'Beglaubigte Übersetzung',
  inLanguage: languages.map((l) => l.iso),
  outLanguage: 'de',
  areaServed: [{ '@type': 'Country', name: 'Germany' }],
  priceRange: 'ab €30,30',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '26',
  },
};

const langCodes = languages.map((l) => ({
  code: l.code.toUpperCase(),
  name: l.name,
  flag: l.flag,
  href: `/beglaubigte-uebersetzung/${l.slug}`,
}));

const sprachen = languages.map((l) => ({
  flag: l.flag,
  name: l.name,
  fact: l.fact,
  href: `/beglaubigte-uebersetzung/${l.slug}`,
  specialization: l.code === 'ua' || l.code === 'ru',
}));

const langCount = languages.length;

const dokumente = [
  { icon: '📄', name: 'Geburtsurkunde',     price: 'ab €30,30', time: 'Standard 72 Std.', href: '/beglaubigte-uebersetzung/geburtsurkunde' },
  { icon: '💍', name: 'Heiratsurkunde',     price: 'ab €30,30', time: 'Standard 72 Std.', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
  { icon: '🚗', name: 'Führerschein',       price: 'ab €30,30', time: 'Standard 72 Std.', href: '/beglaubigte-uebersetzung/fuehrerschein' },
  { icon: '🎓', name: 'Diplom / Zeugnis',   price: 'ab €60,00', time: 'je nach Umfang',   href: '/beglaubigte-uebersetzung/diplom' },
  { icon: '📋', name: 'Führungszeugnis',    price: 'ab €30,30', time: 'Standard 72 Std.', href: '/beglaubigte-uebersetzung/fuehrungszeugnis' },
  { icon: '⚖️', name: 'Gerichtsentscheidung', price: 'auf Anfrage', time: 'je nach Umfang', href: '/beglaubigte-uebersetzung/gerichtsentscheidung' },
  { icon: '🏥', name: 'Medizinische Dok.',  price: 'auf Anfrage', time: 'je nach Umfang', href: '/beglaubigte-uebersetzung/medizinische-dokumente' },
  { icon: '➕', name: 'Anderes Dokument',   price: 'auf Anfrage', time: '',                href: '/app/bestellen', special: true },
];

const behoerden = [
  {
    icon: '💼',
    name: 'Jobcenter',
    content: 'Das Jobcenter übernimmt die Kosten für beglaubigte Übersetzungen nach §44 SGB III. Wir stellen Ihnen eine Rechnung direkt auf das Jobcenter aus — Sie zahlen nichts. Kostenvoranschlag in 30 Min.',
    cta: { text: 'Jetzt Kostenvoranschlag anfordern →', href: '/app/bestellen' },
  },
  {
    icon: '🏢',
    name: 'Agentur für Arbeit',
    content: 'Die Agentur für Arbeit übernimmt Übersetzungskosten nach §44 SGB III. Wir erstellen Ihnen die Rechnung direkt — Sie zahlen 0 €. Kostenvoranschlag in 30 Minuten.',
    cta: { text: 'Kostenlos anfragen →', href: '/app/bestellen' },
  },
  {
    icon: '🌍',
    name: 'Ausländerbehörde',
    content: 'Alle unsere Übersetzungen werden von der Ausländerbehörde deutschlandweit anerkannt — dank Beglaubigung durch den vereidigten Übersetzer am Landgericht Hannover.',
    cta: { text: 'Mehr erfahren →', href: '/beglaubigte-uebersetzungen' },
  },
  {
    icon: '💒',
    name: 'Standesamt',
    content: 'Heiratsurkunden, Geburtsurkunden, Scheidungsurteile — alle Dokumente für das Standesamt übersetzen wir nach ISO 9:1995 Norm.',
    cta: { text: 'Mehr erfahren →', href: '/beglaubigte-uebersetzung/heiratsurkunde' },
  },
  {
    icon: '🎓',
    name: 'Uni-Assist',
    content: 'Für die Zulassung über Uni-Assist benötigen Sie beglaubigte Übersetzungen aller Zeugnisse und Diplome. Unsere Übersetzungen werden von allen deutschen Universitäten akzeptiert.',
    cta: { text: 'Diplom übersetzen →', href: '/beglaubigte-uebersetzung/diplom' },
  },
  {
    icon: '🏛️',
    name: 'BAMF',
    content: 'Für Anerkennungsverfahren beim BAMF müssen alle fremdsprachigen Dokumente von einem vereidigten Übersetzer übersetzt sein. Unsere Übersetzungen werden vollständig anerkannt.',
    cta: { text: 'Jetzt bestellen →', href: '/app/bestellen' },
  },
  {
    icon: '⚖️',
    name: 'Gerichte',
    content: 'Für Gerichtsverfahren in Deutschland müssen Dokumente in anderen Sprachen von einem staatlich anerkannten Übersetzer übersetzt werden. Oleg Rosenblum ist am Landgericht Hannover beeidigt.',
    cta: { text: 'Mehr erfahren →', href: '/beglaubigte-uebersetzungen' },
  },
  {
    icon: '❓',
    name: 'Ihre Behörde nicht dabei?',
    content: 'Unsere Übersetzungen werden von allen deutschen Behörden und Institutionen anerkannt. Kontaktieren Sie uns — wir helfen Ihnen schnell und unkompliziert.',
    cta: { text: 'Kontakt aufnehmen →', href: '/kontakt' },
    special: true,
  },
];

const reviews = [
  {
    stars: 5,
    text: '„Ich kann es zu 100 % empfehlen. So einfach und schnell war es noch nie. Ich musste nur ein Foto des Dokuments und meine Adresse schicken – die Entfernung spielt keine Rolle, alles läuft online. Die Übersetzung war innerhalb eines Tages fertig und wurde sofort versendet. Innerhalb von zwei Tagen nach meiner Anfrage lag die beglaubigte Übersetzung schon im Briefkasten. Sogar die Bezahlung war erst nach Erhalt fällig, innerhalb von 10 Tagen."',
    name: 'Fekriia Akhmetova',
    avatar: '/media/clients/Fekriia_Akhmetova.png',
  },
  {
    stars: 5,
    text: '„Ich brauchte eine Übersetzung eines großen Dokuments. Alles wurde sehr schnell gemacht, die Kommunikation war klar und sachlich. Ich bin wirklich dankbar."',
    name: 'NürVik',
    avatar: '/media/clients/NürVik.png',
  },
  {
    stars: 5,
    text: '„Ich bin mit der Zusammenarbeit sehr zufrieden. Ich habe eine Express-Übersetzung mit einer Bearbeitungszeit von 24 Stunden bestellt. Obwohl die Bestellung erst abends angenommen wurde, war die Übersetzung schon am nächsten Tag bis Mittag fertig und versendet — und bereits am übernächsten Tag hatte ich die Dokumente in der Hand. Besonders positiv überrascht hat mich die Geschwindigkeit: Bei einem anderen Übersetzer dauerten selbst dringende Aufträge etwa eine Woche."',
    name: 'Helena Baida',
    avatar: '/media/clients/Helena_Baida.png',
  },
  {
    stars: 5,
    text: '„Ich habe eine Übersetzung meiner Heirats- und Geburtsurkunden einschließlich Apostillen in Auftrag gegeben. Ich war beeindruckt von der Schnelligkeit und der Liebe zum Detail; dank dieser Arbeitsweise war alles – einschließlich der Zustellung nach Hause – in nur drei Tagen und absolut fehlerfrei erledigt."',
    name: 'Vlad Zhelenko',
    avatar: '/media/clients/Vlad_Zhelenko.png',
  },
];
---

<BaseLayout
  title="Beglaubigte Übersetzungen | Rosenblum Übersetzungsbüro"
  description={`Vereidigter Übersetzer am Landgericht Hannover. Beglaubigte Übersetzungen in ${langCount} Sprachen ab €30,30 — express in 24 Std., deutschlandweit per Post.`}
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/"
  hreflang={{
    de: 'https://rosenblum-uebersetzungen.de/',
    ru: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ru/',
    uk: 'https://rosenblum-uebersetzungen.de/beglaubigte-uebersetzung/ukrainisch-deutsch/ua/',
  }}
  schema={[websiteSchema, translationSchema]}
>
  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · HERO
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-grid">

      <!-- Left: text content -->
      <div class="hero-top">
        <!-- Verified badge -->
        <div class="hero-badge" aria-label="Zertifizierung">
          <span class="badge-dot" aria-hidden="true"></span>
          Vereidigt · Landgericht Hannover
        </div>

        <!-- H1 -->
        <h1 class="hero-h1">
          Beglaubigte<br />
          Übersetzungen in<br />
          <span class="hero-accent">{langCount} Sprachen</span>
        </h1>
      </div>

      <!-- Right: visual -->
      <div class="hero-visual" aria-hidden="true">
        <!-- Floating card top -->
        <div class="hero-float hero-float-top">
          <div class="float-check">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="float-title">Vom Gericht beglaubigt</div>
            <div class="float-sub">Amtlich anerkannt</div>
          </div>
        </div>

        <!-- Document placeholder -->
        <div class="hero-doc">
          <div class="doc-header">
            <div class="doc-circle"></div>
            <div class="doc-lines-header">
              <div class="doc-line" style="width:70%"></div>
              <div class="doc-line" style="width:45%"></div>
            </div>
          </div>
          <div class="doc-body">
            <div class="doc-line" style="width:100%"></div>
            <div class="doc-line" style="width:88%"></div>
            <div class="doc-line" style="width:72%"></div>
          </div>
          <div class="doc-footer">
            <span class="doc-label">— Vereidigter Übersetzer</span>
            <span class="doc-signature">O. Rosenblum</span>
          </div>

          <!-- Blue stamp -->
          <div class="doc-stamp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span class="stamp-line">BEGLAUBIGT</span>
            <span class="stamp-line">LG HANNOVER</span>
          </div>
        </div>

        <!-- Floating card bottom -->
        <div class="hero-float hero-float-bottom">
          <div class="float-icon-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="float-title">Express 24 Std.</div>
            <div class="float-sub">Deutschlandweit per Post</div>
          </div>
        </div>
      </div>

      <!-- Bottom: rest of text content -->
      <div class="hero-bottom">
        <!-- Subline -->
        <p class="hero-sub">
          Vereidigter Übersetzer · Landgericht Hannover ·
          Deutschlandweit anerkannt — ab <strong>€30,30</strong>
        </p>

        <!-- Language row -->
        <div class="lang-row-wrapper" role="group" aria-label="Verfügbare Sprachen">
          <div class="lang-row" id="lang-row">
            {langCodes.map((lang) => (
              <span
                class="lang-code"
                data-name={lang.name}
                data-href={lang.href}
                role="button"
                tabindex="0"
                aria-label={`${lang.name} – zur Sprachseite`}
              >
                <img src={lang.flag} alt="" class="lang-code-flag" width="18" height="13" />
                {lang.code}
                <span class="lang-tooltip" role="tooltip">
                  <strong>{lang.name}</strong>
                  <a href={lang.href} class="tooltip-link">Zur Sprachseite →</a>
                </span>
              </span>
            ))}
          </div>
        </div>

        <!-- CTA block -->
        <div class="hero-ctas">
          <a href="/app/bestellen" class="btn-primary btn-lg hero-cta" aria-label="Kostenvoranschlag anfordern">
            KOSTENVORANSCHLAG BESTELLEN →
          </a>
          <a href="/preise" class="hero-secondary-btn">Zur Preisliste ↓</a>
        </div>

        <!-- Trust stats -->
        <div class="hero-stats" aria-label="Kennzahlen">
          <div class="stats-divider"></div>
          <div class="stats-grid">
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span class="stat-value">8+</span>
              <span class="stat-label">Jahre</span>
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span class="stat-value">10.000+</span>
              <span class="stat-label">Übersetzungen</span>
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="stat-value">5.000+</span>
              <span class="stat-label">Kunden</span>
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <span class="stat-value">{langCount}</span>
              <span class="stat-label">Sprachen</span>
            </div>
            <div class="stat-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-star)" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span class="stat-value">4,8/5</span>
              <span class="stat-label">Google</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · TRANSLATOR SECTION
  ════════════════════════════════════════════════ -->
  <section class="translator" aria-labelledby="translator-h2">
    <div class="container translator-grid">
      <!-- Left: photo placeholder -->
      <div class="translator-photo">
        <img src="/media/oleg.jpg" alt="Oleg Rosenblum" class="photo-image" />
        <div class="translator-badge" aria-label="Zertifizierung">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div>
            <div class="badge-line1">Vereidigt</div>
            <div class="badge-line2">Landgericht Hannover</div>
          </div>
        </div>
      </div>

      <!-- Right: text -->
      <div class="translator-content">
        <div class="section-label"><span class="line"></span>IHR ÜBERSETZER</div>
        <h2 id="translator-h2" class="section-h2">Ihr vereidigter Übersetzer</h2>
        <p class="translator-lead">
          <strong>Oleg Rosenblum</strong> — vom Landgericht Hannover allgemein beeidigter
          Dolmetscher und ermächtigter Übersetzer für die russische und ukrainische Sprache.
        </p>
        <ul class="checklist" aria-label="Qualifikationen">
          {[
            'Über 8 Jahre Erfahrung',
            '10.000+ beglaubigte Übersetzungen',
            'Übersetzungen mit offiziellem Amtssiegel',
            'Spezialist für Ukrainisch und Russisch',
            `Netzwerk vereidigter Übersetzer für ${langCount} Sprachen`,
          ].map((item) => (
            <li class="check-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="https://www.justiz-dolmetscher.de"
          target="_blank"
          rel="noopener noreferrer"
          class="eeat-link"
          aria-label="Oleg im offiziellen Register auf justiz-dolmetscher.de (öffnet in neuem Tab)"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Oleg im offiziellen Register auf justiz-dolmetscher.de →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · BEHÖRDEN ACCORDION
  ════════════════════════════════════════════════ -->
  <section class="behoerden" aria-labelledby="behoerden-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>ANERKANNT BEI</div>
      <h2 id="behoerden-h2" class="section-h2">Anerkannt bei allen deutschen Behörden</h2>
      <p class="section-sub">
        Tippen Sie auf eine Behörde, um zu erfahren, wie wir Ihren Antrag unterstützen.
      </p>

      <div class="behoerden-grid" role="list">
        {behoerden.map((item, i) => (
          <div
            class={`behoerde-item${item.special ? ' behoerde-special' : ''}`}
            role="listitem"
          >
            <button
              class="behoerde-header"
              aria-expanded="false"
              aria-controls={`behoerde-body-${i}`}
              id={`behoerde-btn-${i}`}
            >
              <div class="behoerde-icon-wrap">
                <span class="behoerde-emoji" aria-hidden="true">{item.icon}</span>
              </div>
              <span class="behoerde-name">{item.name}</span>
              <span class="behoerde-toggle" aria-hidden="true">+</span>
            </button>
            <div
              class="behoerde-body"
              id={`behoerde-body-${i}`}
              role="region"
              aria-labelledby={`behoerde-btn-${i}`}
              hidden
            >
              <p class="behoerde-text">{item.content}</p>
              {item.cta && (
                <a href={item.cta.href} class="behoerde-cta">{item.cta.text}</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 5 · SPRACHEN GRID
  ════════════════════════════════════════════════ -->
  <section class="sprachen" aria-labelledby="sprachen-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>UNSERE SPRACHEN</div>
      <h2 id="sprachen-h2" class="section-h2">Übersetzen aus {langCount} Sprachen ins Deutsche</h2>
      <p class="section-sub">
        Wählen Sie Ihre Sprache für detaillierte Informationen, Preise und Bearbeitungszeiten.
      </p>

      <div class="sprachen-grid">
        {sprachen.map((lang) => (
          <a href={lang.href} class="sprache-card" aria-label={`${lang.name} – beglaubigte Übersetzung`}>
            {lang.specialization && <span class="sprache-badge">★ Spezialisierung</span>}
            <img src={lang.flag} alt="" class="sprache-flag" width="40" height="28" />
            <span class="sprache-name">{lang.name}</span>
            <span class="sprache-fact">{lang.fact}</span>
            <span class="sprache-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <p class="sprachen-footer">
        Ihre Sprache nicht dabei?{' '}
        <a href="/kontakt" class="text-link">Kontaktieren Sie uns →</a>
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 6 · WIE ES FUNKTIONIERT
  ════════════════════════════════════════════════ -->
  <section class="steps" aria-labelledby="steps-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>SO EINFACH GEHT'S</div>
      <h2 id="steps-h2" class="section-h2">Beglaubigte Übersetzung in 3 Schritten</h2>

      <div class="steps-grid">
        <!-- Step 1 -->
        <div class="step-card" style="animation-delay: 0ms">
          <div class="step-top">
            <div class="step-number">01</div>
            <div class="step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </div>
          </div>
          <h3 class="step-title">Dokument hochladen</h3>
          <p class="step-text">
            Laden Sie einen Scan oder ein Foto hoch — auch Handyfotos sind ausreichend.
          </p>
          <span class="step-badge step-badge-green">⚡ Kostenvoranschlag in 30 Min.</span>
        </div>

        <div class="step-connector" aria-hidden="true"></div>

        <!-- Step 2 -->
        <div class="step-card" style="animation-delay: 150ms">
          <div class="step-top">
            <div class="step-number">02</div>
            <div class="step-icon">
