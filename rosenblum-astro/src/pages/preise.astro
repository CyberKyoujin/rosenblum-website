<script>
  // ── FAQ accordion ──────────────────────────────
  document.querySelectorAll('.faq-question').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = document.getElementById(btn.getAttribute('aria-controls') ?? '');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-question').forEach((other) => {
        other.setAttribute('aria-expanded', 'false');
        const otherBody = document.getElementById(other.getAttribute('aria-controls') ?? '');
        if (otherBody) otherBody.hidden = true;
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        if (body) body.hidden = false;
      }
    });
  });

  // ── Preisrechner ────────────────────────────────
  const docSelect = document.getElementById('doc-select') as HTMLSelectElement | null;
  const sliderBlock = document.getElementById('slider-block');
  const zeilenSlider = document.getElementById('zeilen-slider') as HTMLInputElement | null;
  const zeilenValue = document.getElementById('zeilen-value');
  const festHint = document.getElementById('fest-hint');
  const resultPrice = document.getElementById('result-price');
  const resultSub = document.getElementById('result-sub');
  const resultTeaser = document.getElementById('result-teaser');
  const expressToggle = document.getElementById('express-toggle') as HTMLInputElement | null;

  let currentDisplayed = 30.30;

  function formatPrice(value: number) {
    return value.toFixed(2).replace('.', ',') + ' €';
  }

  function animatePrice(from: number, to: number, duration = 300) {
    const start = performance.now();
    function update(time: number) {
      const progress = Math.min((time - start) / duration, 1);
      const current = from + (to - from) * progress;
      if (resultPrice) resultPrice.textContent = formatPrice(current);
      if (progress < 1) requestAnimationFrame(update);
      else currentDisplayed = to;
    }
    requestAnimationFrame(update);
  }

  function recalculate() {
    if (!docSelect) return;
    const opt = docSelect.options[docSelect.selectedIndex];
    const type = opt.getAttribute('data-type');
    const isZeile = type === 'zeile';

    if (sliderBlock) sliderBlock.hidden = !isZeile;
    if (festHint) festHint.hidden = isZeile;
    if (resultTeaser) resultTeaser.hidden = !isZeile;

    const expressFactor = expressToggle?.checked ? 1.5 : 1;

    if (isZeile) {
      const priceMin = parseFloat(opt.getAttribute('data-price-min') ?? '0');
      const priceMax = parseFloat(opt.getAttribute('data-price-max') ?? '0');
      const zeilen = parseInt(zeilenSlider?.value ?? '75', 10);
      const totalMin = priceMin * zeilen * expressFactor;
      const totalMax = priceMax * zeilen * expressFactor;

      if (resultPrice) {
        resultPrice.textContent = `ca. ${formatPrice(totalMin)} – ${formatPrice(totalMax)}`;
        resultPrice.classList.add('result-price-range');
      }
      if (resultSub) resultSub.textContent = `bei ${zeilen} Zeilen · 1,40–1,80 € pro Zeile`;
      currentDisplayed = totalMin;
    } else {
      const price = parseFloat(opt.getAttribute('data-price') ?? '0');
      const total = price * expressFactor;
      if (resultSub) resultSub.textContent = 'Festpreis pro Dokument';
      resultPrice?.classList.remove('result-price-range');
      animatePrice(currentDisplayed, total);
    }
  }

  docSelect?.addEventListener('change', recalculate);
  zeilenSlider?.addEventListener('input', () => {
    if (zeilenValue && zeilenSlider) zeilenValue.textContent = zeilenSlider.value;
    recalculate();
  });
  expressToggle?.addEventListener('change', recalculate);

  recalculate();
</script>

