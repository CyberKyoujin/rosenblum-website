---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StickyBar from '../components/StickyBar.astro';

const icons: Record<string, string> = {
  document: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>',
  idcard: '<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>',
  globe: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  graduation: '<path d="M22 10 12 5 2 10l10 5 10-5z"/><path d="M6 12.5V17c3 2.5 9 2.5 12 0v-4.5"/>',
  clipboard: '<rect x="7" y="3" width="10" height="4" rx="1"/><path d="M7 5H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1"/><line x1="8" y1="11" x2="16" y2="11"/><line x1="8" y1="15" x2="16" y2="15"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  stamp: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
};

const priceRowsLeft = [
  { icon: 'document', name: 'Heirats-, Geburts-, Sterbe-, Scheidungsurkunde, Namensänderung', price: '35,30 €' },
  { icon: 'idcard', name: 'Führerschein', price: '30,30 €', highlight: 'Günstigster Einstieg' },
  { icon: 'globe', name: 'Übersetzung der Apostille', price: '10,50 €' },
  { icon: 'idcard', name: 'Pass, Ausweis', price: '35,30 €' },
  { icon: 'home', name: 'Aufenthaltserlaubnis', price: '35,30 €' },
  { icon: 'graduation', name: 'Diplom (ohne Notenanlage)', price: '35,30 €' },
];

const priceRowsRight = [
  { icon: 'graduation', name: 'Reifezeugnisse (Zeugnis + Anlage)', price: '78,90 €' },
  { icon: 'home', name: 'Melde-, Negativbescheinigungen', price: '35,30 €' },
  { icon: 'clipboard', name: 'Bescheinigungen, Zertifikate, Zeugnisse (bis 1 Seite)', price: '35,30 €' },
  { icon: 'shield', name: 'Führungszeugnis', price: '35,30 €' },
  { icon: 'graduation', name: 'Reifezeugnis (ohne Notenanlage)', price: '35,30 €' },
  { icon: 'stamp', name: 'Apostille auf unsere Übersetzung', price: '35,00 €' },
];

const calcOptions = [
  { label: 'Führerschein', type: 'fest', price: 30.30 },
  { label: 'Heirats-, Geburts-, Sterbe-, Scheidungsurkunde', type: 'fest', price: 35.30 },
  { label: 'Pass, Ausweis', type: 'fest', price: 35.30 },
  { label: 'Aufenthaltserlaubnis', type: 'fest', price: 35.30 },
  { label: 'Melde-, Negativbescheinigung', type: 'fest', price: 35.30 },
  { label: 'Führungszeugnis', type: 'fest', price: 35.30 },
  { label: 'Bescheinigung, Zertifikat (bis 1 Seite)', type: 'fest', price: 35.30 },
  { label: 'Reifezeugnis (ohne Notenanlage)', type: 'fest', price: 35.30 },
  { label: 'Reifezeugnis (mit Notenanlage)', type: 'fest', price: 78.90 },
  { label: 'Diplom (ohne Notenanlage)', type: 'fest', price: 35.30 },
  { label: 'Arbeitsbuch', type: 'zeile', priceMin: 1.40, priceMax: 1.80 },
  { label: 'Diplom mit Notenanlage', type: 'zeile', priceMin: 1.40, priceMax: 1.80 },
  { label: 'Gerichtsurteil', type: 'zeile', priceMin: 1.40, priceMax: 1.80 },
  { label: 'Sonstiges Dokument', type: 'zeile', priceMin: 1.40, priceMax: 1.80 },
];

const faqs = [
  {
    q: 'Was kostet eine beglaubigte Übersetzung?',
    a: 'Standarddokumente wie Geburtsurkunde, Heiratsurkunde oder Führerschein kosten bei uns ab 30,30 € inkl. MwSt. – Festpreis, unabhängig von der genauen Seitenzahl. Umfangreichere Dokumente wie Diplome oder Arbeitsbücher werden nach Zeilenpreis (1,40–1,80 € pro Zeile, je nach Komplexität des Dokuments) berechnet. Den genauen Preis erhalten Sie in unserem kostenlosen Kostenvoranschlag innerhalb von 30 Minuten.',
  },
  {
    q: 'Was ist im Preis enthalten?',
    a: 'Im Preis enthalten sind: die vollständige Übersetzung ins Deutsche, der Beglaubigungsvermerk, das offizielle Siegel von Oleg Rosenblum (Landgericht Hannover) und die handschriftliche Unterschrift. Die Übersetzung wird per Post zugestellt – deutschlandweit, ohne Aufpreis.',
  },
  {
    q: 'Wie wird der Preis bei variablen Dokumenten berechnet?',
    a: 'Bei variablen Dokumenten berechnen wir 1,40–1,80 € pro Standardzeile, abhängig von der Komplexität des Dokuments. Eine Standardzeile entspricht 55 Zeichen inkl. Leerzeichen – das ist die in Deutschland übliche Abrechnungseinheit. Die genaue Zeilenzahl ergibt sich aus der fertigen Übersetzung. Im Kostenvoranschlag nennen wir Ihnen den geschätzten Gesamtpreis vorab.',
  },
  {
    q: 'Was kostet Express-Übersetzung?',
    a: 'Express-Übersetzungen (24 Std.) kosten 50% Aufpreis auf den Grundpreis. Beispiel: Geburtsurkunde Standard 35,30 € – Express 52,95 €. Den Express-Aufpreis können Sie im Kostenvoranschlag direkt angeben.',
  },
  {
    q: 'Gibt es versteckte Kosten?',
    a: 'Nein. Der Preis im Kostenvoranschlag ist der Endpreis – inkl. MwSt., Beglaubigung und Postversand innerhalb Deutschlands. Keine Bearbeitungsgebühren, keine Versandkosten, keine Überraschungen.',
  },
  {
    q: 'Kann das Jobcenter die Kosten übernehmen?',
    a: 'Ja. Das Jobcenter und die Agentur für Arbeit können die Kosten für beglaubigte Übersetzungen übernehmen. Sie reichen unseren Kostenvoranschlag bei Ihrem Sachbearbeiter ein – nach Bewilligung zahlt das Jobcenter direkt an uns. Sie müssen nicht in Vorleistung gehen.',
  },
  {
    q: 'Ist der Kostenvoranschlag wirklich kostenlos?',
    a: 'Ja, vollständig kostenlos und unverbindlich. Sie laden Ihr Dokument hoch oder schicken ein Foto – wir prüfen und melden uns innerhalb von 30 Minuten mit dem genauen Preis. Ohne Risiko, ohne Verpflichtung.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rosenblum-uebersetzungen.de/' },
    { '@type': 'ListItem', position: 2, name: 'Preise', item: 'https://rosenblum-uebersetzungen.de/preise/' },
  ],
};
---

<BaseLayout
  title="Preise für beglaubigte Übersetzungen – transparent & fair | Rosenblum"
  description="Was kostet eine beglaubigte Übersetzung? Festpreise ab 30,30 € inkl. MwSt. – Geburtsurkunde, Führerschein, Diplom. Kostenvoranschlag in 30 Min. Jobcenter übernimmt die Kosten."
  lang="de"
  canonicalUrl="https://rosenblum-uebersetzungen.de/preise/"
  schema={[faqSchema, breadcrumbSchema]}
>
  <Navbar currentLang="de" />

  <!-- ═══════════════════════════════════════════════
       SECTION 1 · HERO
  ════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-grid">
      <div class="hero-top">
        <div class="hero-badge" aria-label="Transparenz">
          💰 Transparente Preise · Festpreise · Inkl. MwSt.
        </div>

        <h1 class="hero-h1">
          Preise für beglaubigte<br />
          <span class="hero-accent">Übersetzungen</span>
        </h1>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-float hero-float-top">
          <div class="float-check">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="float-title">Festpreis</div>
            <div class="float-sub">Keine versteckten Kosten</div>
          </div>
        </div>

        <div class="price-card">
          <div class="price-card-header">
            <span class="price-card-label">PREISBEISPIEL</span>
            <span class="price-card-badge">Inkl. MwSt.</span>
          </div>
          <h3 class="price-card-doc">Geburtsurkunde</h3>
          <div class="price-card-rows">
            <div class="price-card-row">
              <span>Beglaubigte Übersetzung</span>
              <span>35,30 €</span>
            </div>
            <div class="price-card-row price-card-row-muted">
              <span>Beglaubigung, Siegel, MwSt. &amp; Versand</span>
              <span>inklusive</span>
            </div>
          </div>
          <div class="price-card-total">
            <span>Gesamt</span>
            <span class="price-card-total-value">35,30 €</span>
          </div>
        </div>

        <div class="hero-float hero-float-bottom">
          <div class="float-icon-blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="float-title">Antwort in 30 Min.</div>
            <div class="float-sub">Kostenlos &amp; unverbindlich</div>
          </div>
        </div>
      </div>

      <div class="hero-bottom">
        <p class="hero-text">
          Was kostet eine beglaubigte Übersetzung? Bei Rosenblum zahlen Sie
          Festpreise ohne versteckte Aufschläge – alle Preise inkl.
          Beglaubigungsvermerk, Siegel und handschriftlicher Unterschrift.
          Führerschein und Geburtsurkunde ab 30,30 €, Express in 24 Std. möglich.
        </p>

        <div class="hero-stats" aria-label="Kennzahlen">
          <span class="hero-stat">✓ Ab 30,30 € Festpreis</span>
          <span class="hero-stat">✓ Alle Preise inkl. MwSt.</span>
          <span class="hero-stat">✓ Keine versteckten Kosten</span>
          <span class="hero-stat">✓ Kostenvoranschlag kostenlos</span>
        </div>

        <div class="hero-ctas">
          <a href="/app/bestellen" class="btn-primary btn-lg hero-cta">KOSTENVORANSCHLAG IN 30 MIN. →</a>
          <a href="/app/bestellen" class="hero-secondary-btn">ÜBERSETZUNG BESTELLEN</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 · PREISMODELL
  ════════════════════════════════════════════════ -->
  <section class="preismodell" aria-labelledby="preismodell-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>PREISMODELL</div>
      <h2 id="preismodell-h2" class="section-h2">Wie wird der Preis einer beglaubigten Übersetzung berechnet?</h2>
      <p class="section-sub">Zwei transparente Preismodelle – je nach Dokumenttyp</p>

      <div class="modell-grid">
        <div class="modell-card">
          <div class="modell-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
          </div>
          <p class="modell-label">STANDARDDOKUMENTE</p>
          <h3 class="modell-h3">Festpreis pro Dokument</h3>
          <p class="modell-text">
            Dokumente mit bekanntem Umfang – Geburtsurkunden, Führerscheine,
            Meldebescheinigungen. Preis ist unabhängig von der genauen Zeilenzahl.
          </p>
          <span class="modell-example">Geburtsurkunde = 35,30 €</span>
        </div>

        <div class="modell-card">
          <div class="modell-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
          </div>
          <p class="modell-label">VARIABLE DOKUMENTE</p>
          <h3 class="modell-h3">1,40–1,80 € pro Zeile</h3>
          <p class="modell-text">
            Dokumente mit variablem Textumfang – Arbeitsbücher, Bildungsdokumente,
            Bescheinigungen. Preis ergibt sich aus tatsächlicher Zeilenzahl der
            Übersetzung und hängt zusätzlich von der Komplexität des Dokuments ab.
          </p>
          <span class="modell-example">Arbeitsbuch 3 Seiten ≈ 105–135 €</span>
        </div>
      </div>

      <div class="info-block">
        <span class="info-icon" aria-hidden="true">ℹ️</span>
        <p>
          <strong>Was ist eine Zeile?</strong> Eine Standardzeile = 55 Zeichen
          inkl. Leerzeichen. Das ist die in Deutschland gültige Abrechnungseinheit
          für Übersetzungen.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 · PREISTABELLE
  ════════════════════════════════════════════════ -->
  <section class="preistabelle" aria-labelledby="preistabelle-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>PREISTABELLE</div>
      <h2 id="preistabelle-h2" class="section-h2">Unsere Preise</h2>
      <p class="section-sub">Festpreise für Standarddokumente inkl. MwSt.</p>

      <div class="preis-columns">
        <div class="preis-col">
          {priceRowsLeft.map((row) => (
            <div class={`preis-row${row.highlight ? ' preis-row-highlight' : ''}`}>
              <svg class="preis-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[row.icon]} />
              <span class="preis-name">
                {row.name}{' '}
                {row.highlight && <span class="preis-tag">{row.highlight}</span>}
              </span>
              <span class="preis-price">
                {row.price}
                <span class="preis-mwst">inkl. MwSt.</span>
              </span>
            </div>
          ))}
        </div>

        <div class="preis-col">
          {priceRowsRight.map((row) => (
            <div class={`preis-row${row.highlight ? ' preis-row-highlight' : ''}`}>
              <svg class="preis-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[row.icon]} />
              <span class="preis-name">
                {row.name}{' '}
                {row.highlight && <span class="preis-tag">{row.highlight}</span>}
              </span>
              <span class="preis-price">
                {row.price}
                <span class="preis-mwst">inkl. MwSt.</span>
              </span>
            </div>
          ))}
        </div>
      </div>

      <div class="express-block">
        <span class="express-icon" aria-hidden="true">⚡</span>
        <p>
          <strong>Express (24 Std.)</strong>{' '}
          <span class="express-aufpreis">+50% Aufpreis</span>
        </p>
      </div>

      <div class="sonstige-block">
        <span class="sonstige-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 1 1 5.83 1c0 2-3 2-3 4"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </span>
        <div class="sonstige-content">
          <h3 class="sonstige-h3">Ihr Dokument nicht dabei?</h3>
          <p class="sonstige-text">
            Diplome mit Anlage, Arbeitsbücher, Gerichtsurteile, Impfpässe,
            Ledigkeitsbescheinigungen und alle anderen Dokumente – wir erstellen
            Ihnen ein individuelles Angebot innerhalb von 30 Minuten.
          </p>
          <p class="sonstige-micro">✓ Kostenlos &amp; unverbindlich &nbsp;·&nbsp; ✓ Antwort in 30 Min.</p>
        </div>
        <a href="/app/bestellen" class="btn-primary sonstige-cta">ANGEBOT ANFORDERN →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 · PREISBEISPIELE
  ════════════════════════════════════════════════ -->
  <section class="beispiele" aria-labelledby="beispiele-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>PREISBEISPIELE</div>
      <h2 id="beispiele-h2" class="section-h2 section-h2-accent">Preisbeispiele</h2>
      <p class="section-sub">So setzen sich die Kosten zusammen</p>

      <div class="beispiele-grid">
        <div class="beispiel-card">
          <div class="beispiel-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            <h3>Geburtsurkunde</h3>
          </div>
          <div class="beispiel-rows">
            <div class="beispiel-row"><span>Geburtsurkunde</span><span>35,30 €</span></div>
            <div class="beispiel-row beispiel-row-muted"><span>+ Apostille-Übersetzung</span><span>10,50 €</span></div>
          </div>
          <div class="beispiel-total">
            <span class="beispiel-total-label">GESAMT</span>
            <span class="beispiel-total-value">45,80 €</span>
          </div>
        </div>

        <div class="beispiel-card">
          <div class="beispiel-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <h3>Heiratsurkunde</h3>
          </div>
          <div class="beispiel-rows">
            <div class="beispiel-row"><span>Heiratsurkunde</span><span>35,30 €</span></div>
            <div class="beispiel-row beispiel-row-muted"><span>+ Apostille-Übersetzung</span><span>10,50 €</span></div>
            <div class="beispiel-row beispiel-row-muted"><span>+ Apostille auf Übersetzung</span><span>35,00 €</span></div>
          </div>
          <div class="beispiel-total">
            <span class="beispiel-total-label">GESAMT</span>
            <span class="beispiel-total-value">80,80 €</span>
          </div>
        </div>

        <div class="beispiel-card beispiel-card-accent">
          <div class="beispiel-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            <h3>Komplexe Dokumente</h3>
          </div>
          <p class="beispiel-desc">
            Diplome mit Europäischem Muster (mit Anlage), Arbeitsbücher,
            Gerichtsurteile und komplexe Dokumente werden nach Zeilenpreis berechnet.
          </p>
          <div class="beispiel-total beispiel-total-individual">
            <span class="beispiel-total-individual-label">Individuelle Berechnung</span>
            <a href="/app/bestellen" class="beispiel-accent-link">Kostenlos anfragen →</a>
          </div>
        </div>

        <div class="beispiel-card beispiel-card-amber">
          <div class="beispiel-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 7h20v13a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V7Z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <h3>Für Jobcenter-Antrag</h3>
          </div>
          <div class="beispiel-rows">
            <div class="beispiel-row"><span>Geburtsurkunde</span><span>35,30 €</span></div>
            <div class="beispiel-row"><span>+ Kostenvoranschlag</span><span class="beispiel-free">kostenlos</span></div>
          </div>
          <div class="beispiel-amber-badge">Kostenübernahme durch Jobcenter möglich</div>
          <a href="#jobcenter" class="text-link beispiel-jc-link">→ Wie beantrage ich Kostenübernahme?</a>
          <div class="beispiel-total">
            <span class="beispiel-total-value">35,30 €</span>
            <span class="beispiel-total-micro">oder 0 € bei Kostenübernahme</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 5 · PREISRECHNER
  ════════════════════════════════════════════════ -->
  <section class="rechner" id="preisrechner" aria-labelledby="rechner-h2">
    <div class="container">
      <div class="section-label"><span class="line"></span>PREISRECHNER</div>
      <h2 id="rechner-h2" class="section-h2 section-h2-accent">Kosten berechnen</h2>
